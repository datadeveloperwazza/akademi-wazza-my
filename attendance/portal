    function renderPhase2(data) {
        if (data.allAttendance) {
            _allAttendance = data.allAttendance;
            // Kira amaran bulan ini dari allAttendance
            var now = new Date();
            var thisMonth = now.getMonth(), thisYear = now.getFullYear();
            var lewatCount = _allAttendance.filter(function(r) {
                if (!r.dateRaw) return false;
                var d = new Date(r.dateRaw + 'T00:00:00');
                return d.getMonth() === thisMonth && d.getFullYear() === thisYear && String(r.status).toUpperCase().includes('LEWAT');
            }).length;
            var warnCard = document.getElementById('warningCard');
            var warnText = document.getElementById('warningText');
            if (lewatCount > 0 && warnCard && warnText) {
                warnText.innerText = lewatCount + ' kelewatan bulan ini';
                warnCard.style.display = 'block';
            } else if (warnCard) { warnCard.style.display = 'none'; }
