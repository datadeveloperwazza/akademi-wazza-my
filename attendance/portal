            else if (cuti.status === "DITOLAK") { badge = `<span class="badge badge-danger">DITOLAK</span>`; cls = "ditolak"; }
            else { badge = `<span class="badge badge-warning">PROSES</span>`; }
            let attachHtml = (cuti.attachment && cuti.attachment !== "Tiada" && cuti.attachment !== "")
                ? `<a href="${cuti.attachment}" target="_blank" style="display:inline-flex;align-items:center;gap:4px;margin-top:8px;font-size:11px;color:#60a5fa;text-decoration:none;">🔗 Lihat Lampiran</a>` : "";
            let rejectHtml = (cuti.status === "DITOLAK" && cuti.rejectReason)
                ? `<div style="margin-top:8px;background:#450a0a;border:1px solid #7f1d1d;border-radius:6px;padding:8px 12px;font-size:11px;color:#fca5a5;"><span style="font-weight:700;display:block;margin-bottom:2px;">⚠️ Sebab Ditolak:</span>${cuti.rejectReason}</div>` : "";
            leaveList.innerHTML += `<div class="leave-card ${cls}">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;">
                    <div><p style="font-size:13px;font-weight:700;text-transform:uppercase;">${cuti.type}</p>
                    <p style="font-size:11px;color:#6b7280;font-family:'Inter',monospace;margin-top:2px;">${cuti.date}</p></div>${badge}</div>
                <div style="background:#111827;border:1px solid #374151;border-radius:6px;padding:10px 12px;font-size:12px;color:#9ca3af;font-style:italic;">"${cuti.reason}"${attachHtml}</div>${rejectHtml}</div>`;
        });

        leaveBalance = data.leaveBalance;
        renderLeaveBalanceWidget(leaveBalance);
        populateLeaveDropdown();
    }

    // ── Wrapper — render both phases (untuk backward compat) ──
    function renderDashboard(data) {
        if (data.status === 'ERROR') { alert(data.message); return; }
        renderPhase1(data);
        renderPhase2(data);
    }

    function renderLeaveBalanceWidget(bal) {
        var widget = document.getElementById('leaveBalanceWidget');
        if (!widget) return;
        if (!bal) {
            widget.innerHTML = '<p style="font-size:12px;color:#6b7280;text-align:center;padding:12px 0;">Tiada data baki cuti.</p>';
            return;
        }
        var types = [
            { key: 'AL', label: 'AL — Cuti Tahunan' },
            { key: 'MC', label: 'MC — Cuti Sakit' },
            { key: 'EL', label: 'EL — Cuti Kecemasan' },
            { key: 'HL', label: 'HL — Hospitalisasi' },
            { key: 'ML', label: 'ML — Cuti Bersalin' },
            { key: 'PL', label: 'PL — Cuti Isteri Bersalin' },
            { key: 'BL', label: 'BL — Cuti Ihsan' }
        ];
        var html = '';
        var hasAny = false;
        types.forEach(function(t) {
            var b = bal[t.key];
            if (!b || b.limit === 0) return; // skip tidak berkenaan
            hasAny = true;
            if (b.unlimited || b.limit === -1) {
                // Unlimited — tunjuk ∞ tanpa progress bar
                html += '<div style="margin-bottom:10px;">' +
                    '<div style="display:flex;justify-content:space-between;align-items:center;">' +
                    '<span style="font-size:11px;font-weight:600;color:#9ca3af;">' + t.label + '</span>' +
                    '<span style="font-size:11px;font-weight:700;color:#eab308;">∞ Tiada Had</span>' +
                    '</div></div>';
            } else {
                var pct = Math.min(100, Math.round((b.used / b.limit) * 100));
                var color = b.balance === 0 ? '#f87171' : b.balance <= Math.ceil(b.limit * 0.2) ? '#eab308' : '#4ade80';
                var balLabel = b.balance === 0
                    ? '<span style="color:#f87171;font-weight:700;">HABIS</span>'
                    : '<span style="color:' + color + ';font-weight:700;">' + b.balance + ' / ' + b.limit + ' hari</span>';
                html += '<div style="margin-bottom:10px;">' +
                    '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;">' +
                    '<span style="font-size:11px;font-weight:600;color:#9ca3af;">' + t.label + '</span>' +
                    balLabel +
                    '</div>' +
                    '<div style="height:5px;background:#374151;border-radius:4px;overflow:hidden;">' +
                    '<div style="height:100%;width:' + pct + '%;background:' + color + ';border-radius:4px;"></div>' +
                    '</div></div>';
            }
        });
        if (bal['UL']) {
            var ulUsed = bal['UL'].used || 0;
            if (hasAny) html += '<div style="height:1px; background:#374151; margin:6px 0;"></div>';
            html += '<div style="display:flex; justify-content:space-between; align-items:center; padding:2px 0;">' +
                '<span style="font-size:11px; font-weight:600; color:#9ca3af;">UL — Tanpa Gaji</span>' +
                '<span style="font-size:11px; font-weight:700; color:' + (ulUsed > 0 ? '#f87171' : '#6b7280') + ';">' + ulUsed + ' hari digunakan</span>' +
                '</div>';
            hasAny = true;
        }
        widget.innerHTML = hasAny ? html : '<p style="font-size:12px;color:#6b7280;text-align:center;padding:8px 0;">Tiada had cuti ditetapkan untuk anda.</p>';
    }

    // Tab switching — sync sidebar nav + bottom nav + topbar title
    const tabTitles = { home: 'Dashboard', attendance: 'Rekod Kehadiran', leave: 'Sejarah Cuti', apply: 'Mohon Cuti' };

    function switchTab(tab) {
        ['home','attendance','leave','apply'].forEach(t => {
            var el = document.getElementById('tab' + t.charAt(0).toUpperCase() + t.slice(1));
            if (el) el.classList.remove('active');
        });
        ['btnHome','btnAtt','btnLeave','btnApply'].forEach(id => {
            var el = document.getElementById(id);
            if (el) el.classList.remove('active');
        });
        ['bnavHome','bnavAtt','bnavLeave','bnavApply'].forEach(id => {
            var el = document.getElementById(id);
            if (el) el.classList.remove('active');
        });

        const panelMap = { home: 'tabHome', attendance: 'tabAttendance', leave: 'tabLeave', apply: 'tabApply' };
        const btnMap   = { home: 'btnHome', attendance: 'btnAtt', leave: 'btnLeave', apply: 'btnApply' };
        const bnavMap  = { home: 'bnavHome', attendance: 'bnavAtt', leave: 'bnavLeave', apply: 'bnavApply' };

        var panel = document.getElementById(panelMap[tab]);
        if (panel) panel.classList.add('active');
        var btn = document.getElementById(btnMap[tab]);
        if (btn) btn.classList.add('active');
        var bnav = document.getElementById(bnavMap[tab]);
        if (bnav) bnav.classList.add('active');

        document.getElementById('topbarTitle').innerText = tabTitles[tab] || 'Portal';
    }

    // ===== KEHADIRAN (Clock In / Out) =====
    var ciCurrentToken = "";
    var ciIntervalId = null;
    var userClockedInToday = false;
    var userClockedOutToday = false;
    var todayClockInTime = '--:--';
    var todayClockOutTime = '--:--';

    function setCiState(state) {
        ['Loading','Closed','In','Out','Done'].forEach(function(s) {
            var el = document.getElementById('ciState' + s);
            if (el) el.style.display = 'none';
        });
        var target = document.getElementById('ciState' + state);
        if (target) target.style.display = '';
    }

    function initKehadiran() {
        var outURL = WEBSITE_URL + "/clockout";
        document.getElementById('coBtnOut').href = outURL;
        checkCiToken();
        if (ciIntervalId) clearInterval(ciIntervalId);
        ciIntervalId = setInterval(checkCiToken, 5000);
    }

    function checkCiToken() {
        callGAS("getDashboardStatus", {}, function(data) {
            if (!data.isOpen) {
                var msgEl = document.getElementById('ciClosedMsg');
                if (msgEl && data.statusMsg) msgEl.innerText = data.statusMsg;
                setCiState('Closed');
                return;
            }

            if (userClockedInToday && userClockedOutToday) {
                document.getElementById('ciInTimeDone').innerText = todayClockInTime;
                document.getElementById('ciOutTimeDone').innerText = todayClockOutTime;
                setCiState('Done');
                return;
            }

            if (userClockedInToday) {
                document.getElementById('ciInTimeDisplay').innerText = todayClockInTime;
                setCiState('Out');
                return;
            }

            // Belum clock in — update token URL secara senyap
            if (data.token && data.token !== ciCurrentToken) {
                ciCurrentToken = data.token;
            }
            var scanURL = WEBSITE_URL + "/scan?token=" + ciCurrentToken;
            document.getElementById('ciBtnIn').href = scanURL;
            var lateNote = document.getElementById('ciLateNote');
            if (lateNote) lateNote.style.display = data.isLate ? '' : 'none';
            // Tukar warna butang kalau lewat
            var btnIn = document.getElementById('ciBtnIn');
            if (btnIn) btnIn.style.background = data.isLate ? '#f97316' : '#4ade80';
            setCiState('In');
        });
    }
</script>
</body>
</html>