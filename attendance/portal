        renderAttendanceLogs(data.attendance || [], "Tiada rekod 10 hari terakhir.");

        const leaveList = document.getElementById('leaveList');
        leaveList.innerHTML = "";
        var leaves = data.leave || [];
        if (leaves.length === 0) {
            leaveList.innerHTML = `<div class="empty-state"><div class="empty-icon">📭</div><p>Tiada sejarah permohonan.</p></div>`;
