    var CACHE_TTL = 15 * 60 * 1000; // 15 minit — sama macam Looker Studio
    var CACHE_VERSION = 'v2'; // naikkan version bila struktur data berubah
    var _allAttendance = []; // semua rekod staff — untuk filter local

    function getDashboardCache(u) {
        try {
            var raw = localStorage.getItem('wazza_dash_' + u);
            if (!raw) return null;
            var obj = JSON.parse(raw);
            // Invalidate kalau expired ATAU version lama (struktur data berubah)
            if (Date.now() - obj.ts > CACHE_TTL || obj.ver !== CACHE_VERSION) {
                localStorage.removeItem('wazza_dash_' + u);
                return null;
            }
            return obj.data;
        } catch(e) { return null; }
    }

    function setDashboardCache(u, data) {
        try { localStorage.setItem('wazza_dash_' + u, JSON.stringify({ ts: Date.now(), ver: CACHE_VERSION, data: data })); } catch(e) {}
    }

    function loadDashboard(u) {
        var cached = getDashboardCache(u);
        if (cached) {
            // Tunjuk cache serta-merta, refresh background
            renderDashboard(cached);
            callGAS("getStaffDashboardData", { username: u }, function(fresh) {
                setDashboardCache(u, fresh);
                renderDashboard(fresh);
            });
        } else {
            document.getElementById('pageLoader').style.display = 'flex';
            callGAS("getStaffDashboardData", { username: u }, function(data) {
                setDashboardCache(u, data);
                renderDashboard(data);
            }, function(err) {
                alert("Gagal menghubungi pelayan. Sila refresh semula.\nSebab: " + err.message);
                document.getElementById('staffName').innerText = "Ralat!";
                document.getElementById('pageLoader').style.display = 'none';
            });
        }
    }

