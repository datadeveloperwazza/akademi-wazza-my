<script>
    // ===== CONFIG =====
    const GAS_URL = "https://script.google.com/macros/s/AKfycbzjwycP8S7eGC_dLML24louH75mM9pOsVxDhTJJ8qE_qSgzPcCKHJhd9hzilAaaMaoT/exec";
    const WEBSITE_URL = "https://urus.wazza.my";
    // ==================

    function callGAS(action, params, onSuccess, onError) {
        if (action === "processCuti") {
            fetch(GAS_URL, {
                method: "POST",
                headers: { "Content-Type": "text/plain" },
                body: JSON.stringify(Object.assign({ action: action }, params || {}))
            })
            .then(function(res) { return res.json(); })
            .then(function(data) { if (onSuccess) onSuccess(data); })
            .catch(function(err) { if (onError) onError(err); else console.error("callGAS error:", action, err); });
            return;
        }
        const url = GAS_URL + "?data=" + encodeURIComponent(JSON.stringify(Object.assign({ action: action }, params || {})));
        fetch(url)
        .then(function(res) {
            if (!res.ok) throw new Error("HTTP " + res.status);
            return res.json();
        })
        .then(function(data) { if (onSuccess) onSuccess(data); })
        .catch(function(err) {
            if (onError) onError(err);
            else console.error("callGAS error:", action, err);
        });
    }

    let currentUser = localStorage.getItem("wazza_nama");
    let leaveRules = { al_advance: 0, al_streak_doc_req: 0, mc_streak_doc_req: 0 };
    let leaveBalance = null;
    let allLeaveTypes = [];

    // Pool map — jenis cuti yang tied kepada limit column
    var leavePoolMap = { AL:'AL', HAL:'AL', MC:'MC', HL:'HL', ML:'ML', PL:'PL', EL:'EL', HEL:'EL', BL:'BL' };

    function populateLeaveDropdown() {
        var select = document.getElementById('formJenis');
        if (!select || allLeaveTypes.length === 0) return;
        var current = select.value;
        select.innerHTML = '<option value="" disabled selected>-- Pilih Jenis --</option>';
        allLeaveTypes.forEach(function(type) {
            var typeUpper = type.trim().toUpperCase();
            var pool = leavePoolMap[typeUpper] || null;
            // Sembunyikan jenis cuti yang limit = 0 (tidak berkenaan)
            // limit = -1 (unlimited) → tunjuk
            if (pool && leaveBalance && leaveBalance[pool] && leaveBalance[pool].limit === 0) return;
            var option = document.createElement("option");
            option.text = type; option.value = type;
            select.add(option);
        });
        // Restore selected value kalau masih wujud dalam list
        if (current) select.value = current;
    }

    // ── Speculative prefetch state ──
    var _prefetch = { ic: null, result: null, pending: false };

    function setupIcPrefetch() {
        document.getElementById('loginIcInput').addEventListener('input', function() {
            var ic = this.value.trim();
            if (ic.length >= 12) {
                if (_prefetch.ic === ic) return;
                _prefetch = { ic: ic, result: null, pending: true };
                // Verify IC sahaja — paling ringan, GAS cached 30 minit
                callGAS("verifyLogin", { u: "", p: ic }, function(res) {
                    if (_prefetch.ic !== ic) return;
                    if (res.status === 'SUCCESS') _prefetch.result = { nama: res.nama };
                    _prefetch.pending = false;
                });
            } else {
                _prefetch = { ic: null, result: null, pending: false };
            }
        });
    }

    window.onload = function () {
        document.getElementById('pageLoader').style.display = 'none';

        if (currentUser) {
            var cached = getDashboardCache(currentUser);
            if (cached) {
                // Ada cache — render terus, tiada loading langsung
                renderPhase1(cached);
                renderPhase2(cached);
                // Background 1: refresh today status (phase 1) — laju
                callGAS("getQuickDashboardData", { username: currentUser }, function(quick) {
                    if (quick.status === 'SUCCESS') renderPhase1(quick);
                });
            } else {
                document.getElementById('pageLoader').style.display = 'flex';
            }
            // Background 2 (selalu): full refresh — update semua + simpan cache baru
            callGAS("getStaffDashboardData", { username: currentUser }, function(full) {
                if (full.status === 'SUCCESS') {
                    setDashboardCache(currentUser, full);
                    if (!cached) {
                        document.getElementById('pageLoader').style.display = 'none';
                        renderPhase1(full);
                    }
                    renderPhase2(full);
                }
            }, function() {
                if (!cached) {
                    document.getElementById('pageLoader').style.display = 'none';
                    alert("Gagal memuatkan data. Sila refresh.");
                }
            });
            setupFormInit();
        } else {
            // Terus tunjuk login — zero delay
            document.getElementById('loginOverlay').classList.add('visible');
            document.getElementById('loginIcInput').focus();
            setupIcPrefetch();
        }
    };

    function setPortalLoginLoading(isLoading) {
        const btn = document.getElementById('btnLogin');
        const btnText = document.getElementById('loginBtnText');
        const spinner = document.getElementById('loginSpinner');
        btn.disabled = isLoading;
        btnText.innerText = isLoading ? "MEMUAT..." : "MASUK";
        spinner.style.display = isLoading ? "block" : "none";
    }

    function _doLoginProgressive(nama, quickData) {
        currentUser = nama;
        localStorage.setItem("wazza_nama", nama);
        // Phase 1: tunjuk dashboard segera
        renderPhase1(quickData);
        // Phase 2: guna cache kalau ada, else skeleton
        var cached = getDashboardCache(nama);
        if (cached) { renderPhase2(cached); } else { showPhase2Skeleton(); }
        setupFormInit();
        // Background: full data
        callGAS("getStaffDashboardData", { username: nama }, function(full) {
            if (full.status === 'SUCCESS') { setDashboardCache(nama, full); renderPhase2(full); }
        });
    }

    // Compat wrapper untuk kes prefetch yang dah ada full data
    function _doLogin(nama, data) {
        currentUser = nama;
        localStorage.setItem("wazza_nama", nama);
        setDashboardCache(nama, data);
        document.getElementById('loginOverlay').classList.remove('visible');
        renderDashboard(data);
        setupFormInit();
    }

    function handlePortalLogin(form) {
        var ic = form.ic.value.trim();
        document.getElementById('loginError').innerText = "";

        // Prefetch dah siap — IC verified, terus show dashboard
        if (_prefetch.result && _prefetch.ic === ic) {
            var nama = _prefetch.result.nama;
            currentUser = nama;
            localStorage.setItem("wazza_nama", nama);
            var cached = getDashboardCache(nama);
            if (cached) {
                renderPhase1(cached); renderPhase2(cached); setupFormInit();
                callGAS("getStaffDashboardData", { username: nama }, function(fresh) {
                    if (fresh.status === 'SUCCESS') { setDashboardCache(nama, fresh); renderPhase1(fresh); renderPhase2(fresh); }
                });
            } else {
                callGAS("loginWithTodayStatus", { ic: ic }, function(quick) {
                    if (quick.status === 'SUCCESS') {
                        renderPhase1(quick); showPhase2Skeleton(); setupFormInit();
                        callGAS("getStaffDashboardData", { username: nama }, function(full) {
                            if (full.status === 'SUCCESS') { setDashboardCache(nama, full); renderPhase2(full); }
                        });
                    }
                });
            }
            return;
        }

        // Prefetch masih running — tunggu
        if (_prefetch.pending && _prefetch.ic === ic) {
            setPortalLoginLoading(true);
            var poll = setInterval(function() {
                if (_prefetch.result) {
                    clearInterval(poll);
                    var nama = _prefetch.result.nama;
                    currentUser = nama; localStorage.setItem("wazza_nama", nama);
                    var cached = getDashboardCache(nama);
                    if (cached) {
                        renderPhase1(cached); renderPhase2(cached); setupFormInit();
                        callGAS("getStaffDashboardData", { username: nama }, function(fresh) {
                            if (fresh.status === 'SUCCESS') { setDashboardCache(nama, fresh); renderPhase1(fresh); renderPhase2(fresh); }
                        });
                    } else {
                        callGAS("loginWithTodayStatus", { ic: ic }, function(quick) {
                            if (quick.status === 'SUCCESS') {
                                renderPhase1(quick); showPhase2Skeleton(); setupFormInit();
                                callGAS("getStaffDashboardData", { username: nama }, function(full) {
                                    if (full.status === 'SUCCESS') { setDashboardCache(nama, full); renderPhase2(full); }
                                });
                            } else { setPortalLoginLoading(false); }
                        }, function() { setPortalLoginLoading(false); });
                    }
                } else if (!_prefetch.pending) {
                    clearInterval(poll); setPortalLoginLoading(false);
                    document.getElementById('loginError').innerText = 'IC tidak ditemui atau tidak sah.';
                }
            }, 100);
            return;
        }

        // Fallback: verify IC dulu (ringan, cached), terus show dashboard
        setPortalLoginLoading(true);
        callGAS("verifyLogin", { u: "", p: ic }, function(res) {
            if (res.status !== 'SUCCESS') {
                setPortalLoginLoading(false);
                document.getElementById('loginError').innerText = res.message || 'IC tidak sah.';
                return;
            }
            var nama = res.nama;
            currentUser = nama;
            localStorage.setItem("wazza_nama", nama);
            var cached = getDashboardCache(nama);
            if (cached) {
                // Ada cache — renderPhase1 will hide login, no need to reset button
                renderPhase1(cached);
                renderPhase2(cached);
                setupFormInit();
                callGAS("getStaffDashboardData", { username: nama }, function(fresh) {
                    if (fresh.status === 'SUCCESS') { setDashboardCache(nama, fresh); renderPhase1(fresh); renderPhase2(fresh); }
                });
            } else {
                // No cache — kekal MEMUAT, renderPhase1 akan hide login terus
                callGAS("loginWithTodayStatus", { ic: ic }, function(quick) {
                    if (quick.status === 'SUCCESS') {
                        renderPhase1(quick);
                        showPhase2Skeleton();
                        setupFormInit();
                        callGAS("getStaffDashboardData", { username: nama }, function(full) {
                            if (full.status === 'SUCCESS') { setDashboardCache(nama, full); renderPhase2(full); }
                        });
                    } else {
                        setPortalLoginLoading(false);
                    }
                }, function() {
                    setPortalLoginLoading(false);
                });
            }
        }, function() {
            setPortalLoginLoading(false);
            document.getElementById('loginError').innerText = "Ralat rangkaian. Cuba semula.";
        });
    }

