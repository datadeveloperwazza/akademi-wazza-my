<!DOCTYPE html>
<html lang="ms">
<head>
    <base target="_top">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }

        :root {
            --bg:           #111827;
            --surface:      #1f2937;
            --surface-2:    #111827;
            --surface-3:    #374151;
            --border:       #374151;
            --border-hover: #4b5563;
            --accent:       #eab308;
            --accent-dim:   rgba(234,179,8,0.08);
            --accent-glow:  rgba(234,179,8,0.20);
            --success:      #4ade80;
            --danger:       #f87171;
            --info:         #60a5fa;
            --text-1:       #f9fafb;
            --text-2:       #9ca3af;
            --text-3:       #6b7280;
            --sidebar-w:    256px;
            --header-h:     64px;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg);
            color:#f9fafb;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Scrollbar ── */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--surface-3); border-radius: 4px; }

        /* ── Page loader ── */
        #pageLoader {
            position: fixed; inset: 0;
            background: #111827;
            z-index: 300;
            display: flex;
            flex-direction: column;
            align-items: center; justify-content: center;
            gap: 16px;
            transition: opacity 0.4s ease;
        }
        #pageLoader.fade-out {
            opacity: 0;
            pointer-events: none;
        }
        .loader-ring {
            width: 40px; height: 40px;
            border: 3px solid #374151;
            border-top-color: #eab308;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Login overlay ── */
        #loginOverlay {
            position: fixed; inset: 0;
            background: #111827;
            z-index: 200;
            display: flex;
            align-items: center; justify-content: center;
            padding: 24px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
        }
        #loginOverlay.visible {
            opacity: 1;
            pointer-events: all;
        }
        .login-card {
            background: #1f2937;
            border: 1px solid #374151;
            border-top: 4px solid #eab308;
            border-radius: 16px;
            padding: 28px 32px 24px;
            width: 100%; max-width: 400px;
            animation: fadeUp 0.4s ease both;
        }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .login-logo {
            width: 40px; height: 40px;
            background: var(--accent-dim);
            border: 1px solid rgba(245,166,35,0.3);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 20px;
            margin: 0 auto 14px;
        }

        /* ── Form elements ── */
        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color:#9ca3af;
            margin-bottom: 6px;
        }
        .form-input {
            width: 100%;
            background: #111827;
            border: 1px solid #374151;
            border-radius: 8px;
            padding: 10px 14px;
            color: #f9fafb;
            font-size: 14px;
            font-family: inherit;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            appearance: none;
        }
        .form-input:focus { border-color: #eab308; box-shadow: 0 0 0 1px #eab308; }
        .form-input::placeholder { color: #6b7280; }
        .form-input[readonly] { opacity: 0.5; cursor: not-allowed; }

        input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.5); cursor: pointer; }

        .btn-primary {
            width: 100%;
            background: #ca8a04;
            color: #111827;
            font-weight: 700;
            font-size: 13px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 12px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            transition: background 0.2s;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-primary:hover { background: #a16207; }
        .btn-primary:active { background: #854d0e; }
        .btn-primary:disabled { opacity: 0.45; cursor: not-allowed; }

        .btn-secondary {
            background: #374151;
            border: 1px solid #4b5563;
            color: #d1d5db;
            font-size: 12px;
            font-weight: 600;
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.15s;
        }
        .btn-secondary:hover { background: #4b5563; color: #f9fafb; }

        /* ── Badges ── */
        .badge {
            display: inline-flex; align-items: center;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }
        .badge-success { background: rgba(74,222,128,0.12); color: #4ade80; border: 1px solid rgba(74,222,128,0.3); }
        .badge-danger  { background: rgba(248,113,113,0.12); color: #f87171; border: 1px solid rgba(248,113,113,0.3); }
        .badge-warning { background: rgba(234,179,8,0.12);   color: #eab308; border: 1px solid rgba(234,179,8,0.3); }
        .badge-muted   { background: #374151; color: #9ca3af; border: 1px solid #4b5563; }

        /* ════════════════════════════════════════
           DESKTOP LAYOUT
        ════════════════════════════════════════ */
        #appShell {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        #sidebar {
            width: var(--sidebar-w);
            background: #1f2937;
            border-right: 1px solid #374151;
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 50;
            transition: transform 0.3s ease;
        }

        .sidebar-brand {
            padding: 20px 20px 16px;
            border-bottom: 1px solid #374151;
            display: flex; align-items: center; gap: 12px;
        }
        .sidebar-brand-icon {
            width: 36px; height: 36px;
            background: rgba(234,179,8,0.08);
            border: 1px solid rgba(234,179,8,0.3);
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            font-size: 17px; flex-shrink: 0;
        }
        .sidebar-brand-text {
            font-size: 13px; font-weight: 700;
            color:#f9fafb;
            line-height: 1.2;
        }
        .sidebar-brand-sub {
            font-size: 10px; color: #eab308;
            font-weight: 600; letter-spacing: 0.05em;
        }

        /* Profile block in sidebar */
        .sidebar-profile {
            padding: 16px 20px;
            border-bottom: 1px solid #374151;
            display: flex; align-items: center; gap: 12px;
        }
        .avatar-wrap { position: relative; flex-shrink: 0; }
        .avatar-wrap img {
            width: 42px; height: 42px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #eab308;
        }
        .avatar-dot {
            position: absolute; bottom: 1px; right: 1px;
            width: 10px; height: 10px;
            background: #4ade80;
            border: 2px solid #1f2937;
            border-radius: 50%;
        }
        .sidebar-profile-name { font-size: 13px; font-weight: 600; color:#f9fafb; }
        .sidebar-profile-role { font-size: 10px; color: #eab308; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
        .sidebar-profile-id   { font-size: 10px; color:#6b7280; font-family: 'Inter', monospace; margin-top: 1px; }

        /* Nav items */
        .sidebar-nav { flex: 1; padding: 12px 10px; overflow-y: auto; }
        .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 13px; font-weight: 500;
            color: #9ca3af;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
            margin-bottom: 2px;
            border: none; background: none; width: 100%; text-align: left;
        }
        .nav-item:hover { background: #374151; color: #f9fafb; }
        .nav-item.active { background: #eab308; color: #111827; font-weight: 700; }
        .nav-item .nav-icon { font-size: 16px; width: 20px; text-align: center; flex-shrink: 0; }

        .sidebar-footer {
            padding: 12px 10px;
            border-top: 1px solid #374151;
        }

        /* Main content area */
        #mainContent {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Top bar (desktop) */
        #topbar {
            height: var(--header-h);
            background: #1f2937;
            border-bottom: 1px solid #374151;
            display: flex; align-items: center;
            padding: 0 32px;
            position: sticky; top: 0; z-index: 40;
        }
        .topbar-title { font-size: 16px; font-weight: 600; color:#f9fafb; }
        .topbar-sub { font-size: 12px; color:#6b7280; margin-top: 1px; font-family: 'Inter', monospace; }

        /* Content panels */
        #contentArea { flex: 1; padding: 32px; max-width: 1100px; }

        /* Tab panels */
        .tab-panel { display: none; animation: fadeUp 0.25s ease both; }
        .tab-panel.active { display: block; }

        /* Cards */
        .card {
            background: #1f2937;
            border: 1px solid #374151;
            border-radius: 12px;
            padding: 20px;
        }
        .card-sm { padding: 16px; }

        .section-title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            color: #6b7280;
            margin-bottom: 12px;
        }

        /* Stat cards */
        .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
        .stat-card {
            background: #1f2937;
            border: 1px solid #374151;
            border-radius: 10px;
            padding: 16px;
            text-align: center;
        }
        .stat-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #6b7280; margin-bottom: 6px; }
        .stat-val { font-size: 28px; font-weight: 800; font-family: 'Inter', monospace; line-height: 1; }

        /* Today card */
        .today-card {
            background: #1f2937;
            border: 1px solid #374151;
            border-left: 4px solid #6b7280;
            border-radius: 12px;
            padding: 20px 24px;
        }
        .today-card.hadir  { border-left-color: #4ade80; }
        .today-card.lewat  { border-left-color: #f87171; }
        .today-card.absent { border-left-color: #6b7280; }

        .time-big { font-family: 'Inter', monospace; font-size: 36px; font-weight: 700; line-height: 1; }

        /* Log rows */
        .log-row {
            background: #1f2937;
            border: 1px solid #374151;
            border-left: 4px solid #6b7280;
            border-radius: 10px;
            padding: 14px 16px;
            display: flex; align-items: center; justify-content: space-between;
            gap: 12px;
        }
        .log-row.hadir { border-left-color: #4ade80; }
        .log-row.lewat { border-left-color: #f87171; }

        .leave-card {
            background: #1f2937;
            border: 1px solid #374151;
            border-left: 4px solid #6b7280;
            border-radius: 10px;
            padding: 16px;
        }
        .leave-card.lulus   { border-left-color: #4ade80; }
        .leave-card.ditolak { border-left-color: #f87171; }
        .leave-card.proses  { border-left-color: #eab308; }

        /* Desktop home — 2-col */
        @media (min-width: 1024px) {
            .home-grid {
                display: grid;
                grid-template-columns: 1fr 380px;
                gap: 20px;
                align-items: start;
            }
            .home-left { display: flex; flex-direction: column; gap: 20px; }
            .home-right { display: flex; flex-direction: column; gap: 20px; }
        }
        @media (max-width: 1023px) {
            .home-grid { display: flex; flex-direction: column; gap: 16px; }
        }

        /* Form styling */
        .apply-form-wrap {
            background: #1f2937;
            border: 1px solid #374151;
            border-radius: 12px;
            padding: 24px;
            position: relative; overflow: hidden;
        }
        @media (min-width: 768px) {
            .date-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        }

        /* ════════════════════════════════════════
           MOBILE LAYOUT — override sidebar to bottom nav
        ════════════════════════════════════════ */
        @media (max-width: 767px) {
            :root { --sidebar-w: 0px; }

            #sidebar { display: none; }


            #mainContent { margin-left: 0; padding-bottom: 72px; }

            /* Mobile header */
            #mobileHeader {
                display: flex !important;
                position: sticky; top: 0; z-index: 50;
                height: 60px;
                background: #1f2937;
                border-bottom: 1px solid #374151;
                align-items: center;
                padding: 0 16px;
                gap: 12px;
            }
            #mobileHeader .mob-avatar img {
                width: 34px; height: 34px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid #eab308;
            }
            #mobileHeader .mob-name { font-size: 14px; font-weight: 600; }
            #mobileHeader .mob-role { font-size: 10px; color: #eab308; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }

            /* Hide desktop topbar on mobile */
            #topbar { display: none; }

            #contentArea { padding: 16px; max-width: 100%; }

            /* Bottom nav */
            #bottomNav {
                display: flex !important;
                position: fixed; bottom: 0; left: 0; right: 0;
                height: 64px;
                background: #1f2937;
                border-top: 1px solid #374151;
                z-index: 50;
            }
            .bnav-item {
                flex: 1; display: flex; flex-direction: column;
                align-items: center; justify-content: center;
                gap: 3px;
                font-size: 9px; font-weight: 600;
                text-transform: uppercase; letter-spacing: 0.04em;
                color: #6b7280;
                cursor: pointer;
                border: none; background: none;
                transition: color 0.15s;
                padding: 0;
            }
            .bnav-item .bnav-icon { font-size: 18px; line-height: 1; }
            .bnav-item.active { color: #eab308; }

            .stat-val { font-size: 24px; }
            .time-big { font-size: 28px; }
        }

        @media (min-width: 768px) {
            #mobileHeader { display: none; }
            #bottomNav { display: none; }
        }

        /* Textarea */
        textarea.form-input { resize: vertical; min-height: 90px; }

        /* File input */
        .file-input-wrap { position: relative; }
        .file-input-wrap input[type="file"] {
            width: 100%;
            background: #111827;
            border: 1px dashed #4b5563;
            border-radius: 8px;
            padding: 10px 14px;
            color: #9ca3af;
            font-size: 12px;
            font-family: inherit;
            cursor: pointer;
        }
        .file-input-wrap input[type="file"]::-webkit-file-upload-button {
            background: #ca8a04;
            color: #111827;
            border: none;
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            cursor: pointer;
            margin-right: 12px;
            font-family: inherit;
        }

        /* Success card */
        .success-card {
            background: #1f2937;
            border: 1px solid rgba(74,222,128,0.3);
            border-radius: 12px;
            padding: 40px 24px;
            text-align: center;
        }

        /* Warning box */
        .rule-warning {
            background: rgba(248,113,113,0.08);
            border: 1px solid rgba(248,113,113,0.3);
            border-radius: 8px;
            padding: 12px 14px;
            font-size: 12px;
            font-weight: 600;
            color: #f87171;
        }

        /* Date search bar */
        .date-search-bar {
            background: #1f2937;
            border: 1px solid #374151;
            border-radius: 10px;
            padding: 16px;
            display: flex; align-items: flex-end; gap: 10px; flex-wrap: wrap;
        }
        .date-search-bar .field { flex: 1; min-width: 120px; }

        /* Spinner for buttons */
        .btn-spinner {
            width: 16px; height: 16px;
            border: 2px solid rgba(0,0,0,0.2);
            border-top-color: #111827;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            display: none;
        }

        /* GPS loader overlay */
        #gpsLoader {
            position: absolute; inset: 0;
            background: rgba(17,24,39,0.92);
            z-index: 50;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            border-radius: 12px;
        }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 32px 16px;
            color: #6b7280;
            font-size: 13px;
        }
        .empty-state .empty-icon { font-size: 28px; margin-bottom: 8px; }

        /* Divider */
        .divider { height: 1px; background: #374151; margin: 4px 0; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(6px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-in { animation: fadeIn 0.25s ease both; }
    </style>
</head>
<body class="bg-gray-900">

<!-- ══════════ PAGE LOADER ══════════ -->
<div id="pageLoader">
    <div class="loader-ring"></div>
    <p style="font-size:11px; font-weight:700; letter-spacing:0.1em; color:#eab308;">MENYEDIAKAN PORTAL...</p>
</div>

<!-- ══════════ LOGIN OVERLAY ══════════ -->
<div id="loginOverlay">
    <div class="login-card">
        <h2 style="text-align:center; font-size:18px; font-weight:800; margin-bottom:4px;">Log Masuk</h2>
        <p style="text-align:center; font-size:12px; color:#6b7280; margin-bottom:20px;">Sila log masuk untuk akses Portal Staf</p>

        <form onsubmit="handlePortalLogin(this); return false;" style="display:flex; flex-direction:column; gap:16px;">
            <div>
                <label class="form-label">No. Kad Pengenalan (IC)</label>
                <input type="text" name="ic" id="loginIcInput" required placeholder="Contoh: 901231012345" class="form-input" inputmode="numeric" autocomplete="off">
            </div>
            <button type="submit" id="btnLogin" class="btn-primary" style="margin-top:4px;">
                <span id="loginBtnText">MASUK</span>
                <svg id="loginSpinner" style="display:none;" class="btn-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
            </button>
            <p id="loginError" style="text-align:center; font-size:12px; color:#f87171; min-height:16px;"></p>
            <p style="text-align:center; font-size:11px; color:#6b7280;">Masalah log masuk? Hubungi <span style="color:#eab308; font-weight:600;">Admin</span>.</p>
        </form>
        <div style="margin-top:14px; padding-top:12px; border-top:1px solid #374151; text-align:center;">
            <a href="admin" style="display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:600; color:#6b7280; text-decoration:none; transition:color 0.15s;" onmouseover="this.style.color='#eab308'" onmouseout="this.style.color='#6b7280'">
                ⚙️ Pergi ke Admin Panel
            </a>
        </div>
    </div>
</div>

<!-- ══════════ APP SHELL ══════════ -->
<div id="appShell" style="display:none;">

    <!-- SIDEBAR (desktop) -->
    <aside id="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">⚡</div>
            <div>
                <div class="sidebar-brand-text">WAZZA</div>
                <div class="sidebar-brand-sub">Staff Portal</div>
            </div>
        </div>

        <div class="sidebar-profile">
            <div class="avatar-wrap">
                <img id="profilePic" src="https://via.placeholder.com/150" alt="profile">
                <div class="avatar-dot"></div>
            </div>
            <div style="min-width:0;">
                <div id="staffName" class="sidebar-profile-name" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Loading...</div>
                <div id="staffRole" class="sidebar-profile-role">...</div>
                <div id="staffID" class="sidebar-profile-id">ID: ...</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <button onclick="switchTab('home')" id="btnHome" class="nav-item active">
                <span class="nav-icon">🏠</span> Dashboard
            </button>
            <button onclick="switchTab('attendance')" id="btnAtt" class="nav-item">
                <span class="nav-icon">📅</span> Rekod Kehadiran
            </button>
            <button onclick="switchTab('leave')" id="btnLeave" class="nav-item">
                <span class="nav-icon">📋</span> Sejarah Cuti
            </button>
            <button onclick="switchTab('apply')" id="btnApply" class="nav-item">
                <span class="nav-icon">📝</span> Mohon Cuti
            </button>
        </nav>

        <div class="sidebar-footer">
            <button onclick="logoutPortal()" class="btn-secondary" style="width:100%; font-size:12px;">
                🚪 Keluar Sistem
            </button>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div id="mainContent">

        <!-- Mobile header -->
        <header id="mobileHeader" style="display:none;">
            <div class="mob-avatar avatar-wrap" style="flex-shrink:0;">
                <img id="profilePicMob" src="https://via.placeholder.com/150" alt="">
                <div class="avatar-dot"></div>
            </div>
            <div style="flex:1; min-width:0;">
                <div id="staffNameMob" class="mob-name" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Loading...</div>
                <div id="staffRoleMob" class="mob-role">...</div>
            </div>
            <button onclick="logoutPortal()" style="background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.25); color:#f87171; font-size:11px; font-weight:700; padding:6px 12px; border-radius:8px; cursor:pointer; flex-shrink:0;">
                Keluar
            </button>
        </header>

        <!-- Desktop topbar -->
        <header id="topbar">
            <div>
                <div class="topbar-title" id="topbarTitle">Dashboard</div>
                <div class="topbar-sub" id="topbarSub">Selamat datang</div>
