    function validateLeaveRules() {
        let jenis = document.getElementById('formJenis').value || "";
        let tmInput = document.getElementById('formTarikhMula').value;
        let ttInput = document.getElementById('formTarikhTamat').value;
        if (!jenis || !tmInput || !ttInput) return;

        let tm = new Date(tmInput); let tt = new Date(ttInput);
        let todayStr = getLocalISODate(); let todayObj = new Date(todayStr);
        let btn = document.getElementById('btnSubmitLeave');
        let fileInput = document.getElementById('formFile');
        let warningBox = document.getElementById('ruleWarning');
        let labelLampiran = document.getElementById('labelLampiran');

        btn.disabled = false;
        fileInput.required = false;
        warningBox.style.display = 'none';
        warningBox.innerHTML = "";
        labelLampiran.innerHTML = `Bukti Lampiran <span style="color:#6b7280; font-weight:400; text-transform:none; letter-spacing:0;">(Pilihan — Max 2MB)</span>`;

        if (jenis.includes("Lambat")) return;

        let timeDiff = tt.getTime() - tm.getTime();
        let dayStreak = Math.ceil(timeDiff / (1000 * 3600 * 24)) + 1;
        let advanceDiff = tm.getTime() - todayObj.getTime();
        let advanceDays = Math.ceil(advanceDiff / (1000 * 3600 * 24));

        let jenisUpper = jenis.trim().toUpperCase();
        let isMC = jenisUpper === "MC";
        let isAL = jenisUpper === "AL" || jenisUpper === "HAL";
        let isEL = jenisUpper === "EL" || jenisUpper === "HEL";

        let errors = []; let needsDoc = false;
        if (isMC && leaveRules.mc_streak_doc_req > 0 && dayStreak >= leaveRules.mc_streak_doc_req) { needsDoc = true; }
        if ((isAL || isEL) && leaveRules.al_streak_doc_req > 0 && dayStreak > leaveRules.al_streak_doc_req) { needsDoc = true; }
        if (isAL && leaveRules.al_advance > 0 && advanceDays < leaveRules.al_advance) {
            errors.push(`⚠️ AL wajib dimohon sekurang-kurangnya ${leaveRules.al_advance} hari lebih awal. Sila tukar kepada EL jika ini kes kecemasan.`);
        }

        // Semak baki cuti
        if (leaveBalance) {
            var poolMap = { AL: 'AL', HAL: 'AL', MC: 'MC', HL: 'HL', ML: 'ML', PL: 'PL', EL: 'EL', HEL: 'EL', BL: 'BL' };
            var halfDayTypes = ['HAL', 'HEL', 'HUL'];
            var pool = poolMap[jenisUpper];
            if (pool && leaveBalance[pool] && leaveBalance[pool].balance !== null) {
                var b = leaveBalance[pool];
                var daysRequested = halfDayTypes.includes(jenisUpper) ? 0.5 : dayStreak;
                if (b.balance <= 0) {
                    errors.push(`⛔ Baki cuti <strong>${pool}</strong> telah habis (0 hari berbaki). Sila hubungi admin.`);
                } else if (b.balance < daysRequested) {
                    errors.push(`⛔ Baki cuti <strong>${pool}</strong> tidak mencukupi. Baki: <strong>${b.balance} hari</strong>, dimohon: <strong>${daysRequested} hari</strong>.`);
                }
            }
        }

        if (needsDoc) {
            fileInput.required = true;
            labelLampiran.innerHTML = `Bukti Lampiran <span style="color:#f87171; font-weight:700;">* (WAJIB MUAT NAIK)</span>`;
        }
        if (errors.length > 0) {
            warningBox.innerHTML = errors.join("<br><br>");
            warningBox.style.display = 'block';
            btn.disabled = true;
        }
    }

