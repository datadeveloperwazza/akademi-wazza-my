    function handleLeaveSubmit(form) {
        const fileInput = document.getElementById('formFile');
        const file = fileInput.files[0];
        if (fileInput.required && !file) {
            alert("Ralat Sistem: Cuti ini wajib disertakan dengan bukti lampiran.");
            return;
        }
        document.getElementById('gpsLoader').style.display = 'flex';
        const btn = document.getElementById('btnSubmitLeave');
        btn.disabled = true;

        if (file) {
            if (file.size > 2097152) {
                alert("Saiz fail terlalu besar! Sila pastikan saiz fail bawah 2MB.");
                resetSubmitState(); return;
            }
            const reader = new FileReader();
            reader.onload = function (e) {
                const base64Data = e.target.result.split(',')[1];
                sendData(form, base64Data, file.type, file.name);
            };
            reader.readAsDataURL(file);
        } else {
            sendData(form, null, null, null);
        }
    }

    function sendData(form, fileData, mimeType, fileName) {
        const formData = {
            nama: form.nama.value,
            jenis: form.jenis.value,
            tarikhMula: form.tarikhMula.value,
            tarikhTamat: form.tarikhTamat.value,
