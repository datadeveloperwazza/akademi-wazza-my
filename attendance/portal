            fileData: fileData, mimeType: mimeType, fileName: fileName
        };
        callGAS("processCuti", { formData: formData }, function (response) {
            resetSubmitState();
            if (response && response.status === 'ERROR') { alert(response.message); return; }
            document.getElementById('leaveForm').style.display = 'none';
            document.getElementById('formSuccess').style.display = 'block';
            loadDashboard(currentUser);
