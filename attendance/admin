        function populateConfigForm(data) {
            // Masa QR
            document.getElementById('cfg_startQr').value = data.startQr || "";
            document.getElementById('cfg_endQr').value = data.endQr || "";
            document.getElementById('cfg_lateStart').value = data.lateStart || "";

