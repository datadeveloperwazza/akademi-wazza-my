                    '</tr></thead>' +
                    '<tbody id="htbl_' + dayData.dateRaw + '" class="divide-y divide-gray-700"></tbody>' +
                    '</table></div>';
                container.appendChild(div);
                renderHistoryRows('htbl_' + dayData.dateRaw, dayData.attendance, dayData.date, dayData.calendarEvents);
            });
