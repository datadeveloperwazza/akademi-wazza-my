        function switchOutstationTab(tab) {
            currentOutstationTab = tab;
            ['upcoming', 'previous', 'all'].forEach(function(t) {
                var el = document.getElementById('tab-' + t);
                if (!el) return;
                el.className = t === tab
                    ? 'ost-tab px-3 py-1 rounded-md text-xs font-bold transition bg-blue-600 text-white'
                    : 'ost-tab px-3 py-1 rounded-md text-xs font-bold transition text-gray-400 hover:text-white';
            });
            filterAndRenderOutstation();
        }

        function filterAndRenderOutstation() {
            var dateInput = document.getElementById('outstationDateFilter');
            var dateFilter = dateInput ? dateInput.value : '';
            var today = new Date();
            var todayStr = today.getFullYear() + '-' + String(today.getMonth() + 1).padStart(2, '0') + '-' + String(today.getDate()).padStart(2, '0');
            var filtered = globalOutstationList.filter(function(rec) {
                if (dateFilter && rec.tarikh !== dateFilter) return false;
                if (currentOutstationTab === 'upcoming') return rec.tarikh >= todayStr;
                if (currentOutstationTab === 'previous') return rec.tarikh < todayStr;
                return true;
            });
            renderOutstationTable(filtered);
        }

        function onOutstationDateChange() {
            var input = document.getElementById('outstationDateFilter');
            var dateVal = input ? input.value : '';
            if (dateVal) {
                switchOutstationTab('all');
            } else {
                switchOutstationTab('upcoming');
            }
        }

        function clearOutstationFilter() {
            var input = document.getElementById('outstationDateFilter');
            if (input) input.value = '';
            switchOutstationTab('upcoming');
        }

        function loadOutstationList(forceRefresh) {
            if (!forceRefresh && isCacheValid('outstationList')) { globalOutstationList = appCache.outstationList.data; filterAndRenderOutstation(); return; }
            var tbody = document.getElementById('tableOutstation');
            tbody.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-yellow-500 animate-pulse">Menarik Data Outstation...</td></tr>';
            callGAS("getOutstationList", {}, function (res) {
                if (res.status === 'SUCCESS') {
                    setCache('outstationList', res.data);
                    globalOutstationList = res.data;
                    filterAndRenderOutstation();
                } else {
                    tbody.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-red-500">' + (res.message || 'Ralat') + '</td></tr>';
                }
            });
        }

        function renderOutstationTable(list) {
            var tbody = document.getElementById('tableOutstation');
            tbody.innerHTML = "";
            if (list.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="p-8 text-center text-gray-500">Tiada rekod pengecualian outstation.</td></tr>';
                return;
            }

            list.sort(function (a, b) { return b.tarikh.localeCompare(a.tarikh); });

            var today = new Date();
            var todayStr = today.getFullYear() + "-" + String(today.getMonth() + 1).padStart(2, '0') + "-" + String(today.getDate()).padStart(2, '0');

            list.forEach(function (rec) {
                var statusBadge = "";
                if (rec.status === "DONE") {
                    statusBadge = '<span class="bg-green-900 text-green-300 px-2 py-1 rounded text-xs font-bold border border-green-700">SELESAI</span>';
                } else if (rec.tarikh < todayStr) {
                    statusBadge = '<span class="bg-gray-700 text-gray-500 px-2 py-1 rounded text-xs font-bold border border-gray-600">TAMAT</span>';
                } else {
                    statusBadge = '<span class="bg-blue-900 text-blue-300 px-2 py-1 rounded text-xs font-bold border border-blue-700">AKTIF</span>';
                }

                var parts = rec.tarikh.split("-");
                var tarikhDisplay = parts.length === 3 ? parts[2] + "/" + parts[1] + "/" + parts[0] : rec.tarikh;
                var isToday = rec.tarikh === todayStr;

                var autoHtml = rec.autoClockIn
                    ? '<span class="bg-blue-900 text-blue-300 px-2 py-0.5 rounded text-xs border border-blue-700 font-bold">✓ ' + (rec.masaClockIn || "08:00") + '</span>'
                    : '<span class="text-gray-600 text-xs">—</span>';

                var todayBadge = isToday ? ' <span class="text-[10px] bg-yellow-500 text-gray-900 px-1.5 py-0.5 rounded font-bold ml-1">HARI INI</span>' : '';

                tbody.innerHTML += '<tr class="hover:bg-gray-700/30 border-b border-gray-700/50 transition' + (isToday ? ' bg-blue-900/10' : '') + '">' +
                    '<td class="p-4 font-bold text-white">' + rec.nama + '</td>' +
                    '<td class="p-4"><span class="font-mono text-sm ' + (isToday ? 'text-yellow-400 font-bold' : 'text-gray-300') + '">' + tarikhDisplay + todayBadge + '</span></td>' +
                    '<td class="p-4">' + autoHtml + '</td>' +
                    '<td class="p-4 text-xs text-gray-400 italic max-w-[200px]"><span class="line-clamp-2">' + (rec.sebab || '—') + '</span></td>' +
                    '<td class="p-4 text-center">' + statusBadge + '</td>' +
                    '<td class="p-4 text-center flex gap-1 justify-center">' +
                    '<button onclick="openOutstationModal(' + rec.rowIndex + ')" class="bg-yellow-900 hover:bg-yellow-800 text-yellow-200 border border-yellow-700 px-3 py-1 rounded text-xs font-bold transition">Edit</button>' +
                    '<button onclick="deleteOutstationRecord(' + rec.rowIndex + ')" class="bg-red-900 hover:bg-red-800 text-red-200 border border-red-700 px-3 py-1 rounded text-xs font-bold transition">Padam</button>' +
                    '</td></tr>';
            });
        }

        function openOutstationModal(rowIndex) {
            // Reset form
            document.getElementById('ost_rowIndex').value = "";
            document.getElementById('ost_tarikh').value = "";
            document.getElementById('ost_autoClockIn').checked = false;
            document.getElementById('ost_masaClockIn').value = "08:00";
            document.getElementById('ost_sebab').value = "";
            document.getElementById('autoClockInTimeSection').classList.add('hidden');

            // Resolve edit record
            var editRec = (rowIndex !== undefined && rowIndex !== null)
                ? globalOutstationList.find(function (r) { return r.rowIndex === rowIndex; })
                : null;

            var sel = document.getElementById('ost_nama');
            var multiContainer = document.getElementById('ost_multiContainer');

            if (editRec) {
                document.getElementById('outstationModalTitle').innerText = "Kemaskini Pengecualian";
                document.getElementById('ost_rowIndex').value = editRec.rowIndex;
                document.getElementById('ost_tarikh').value = editRec.tarikh;
                document.getElementById('ost_autoClockIn').checked = editRec.autoClockIn;
                document.getElementById('ost_masaClockIn').value = editRec.masaClockIn || "08:00";
                document.getElementById('ost_sebab').value = editRec.sebab || "";
                if (editRec.autoClockIn) document.getElementById('autoClockInTimeSection').classList.remove('hidden');
                // Edit: single select + single date
                sel.classList.remove('hidden');
                multiContainer.classList.add('hidden');
                document.getElementById('ost_tarikhSingleWrap').classList.remove('hidden');
                document.getElementById('ost_tarikhRangeWrap').classList.add('hidden');
            } else {
                document.getElementById('outstationModalTitle').innerText = "Tambah Pengecualian Outstation";
                document.getElementById('ost_tarikhDari').value = '';
                document.getElementById('ost_tarikhHingga').value = '';
                document.getElementById('ost_selectedChips').classList.add('hidden');
                document.getElementById('ost_chipsContainer').innerHTML = '';
                // Add: multi checkbox + date range
                sel.classList.add('hidden');
                multiContainer.classList.remove('hidden');
                document.getElementById('ost_tarikhSingleWrap').classList.add('hidden');
                document.getElementById('ost_tarikhRangeWrap').classList.remove('hidden');
            }

            var modal = document.getElementById('outstationModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');

            var reqId = ++outstationModalReqId;

            // Filter: aktif + paparTracker = true sahaja
            function getVisibleStaffNames(list) {
                if (list && list.length > 0 && typeof list[0] === 'object') {
                    return list.filter(function(s) { return s.paparTracker !== false && s.status && s.status.toUpperCase() === 'AKTIF'; }).map(function(s) { return s.nama; });
                }
                return list || [];
            }

            function fillSelect(names) {
                if (reqId !== outstationModalReqId) return;
                sel.disabled = false;
                sel.innerHTML = '<option value="">-- Pilih Staf --</option>';
                names.forEach(function(n) { sel.innerHTML += '<option value="' + n + '">' + n + '</option>'; });
                if (editRec) sel.value = editRec.nama;
            }

            function fillChecklist(names) {
                if (reqId !== outstationModalReqId) return;
                var list = document.getElementById('ost_staffChecklist');
                list.innerHTML = names.map(function(n) {
                    return '<label class="flex items-center gap-2 px-2 py-1.5 rounded hover:bg-gray-700 cursor-pointer ost-staff-item">' +
                        '<input type="checkbox" class="ost-staff-check" value="' + n + '" onchange="updateOstChips()">' +
                        '<span class="text-sm text-white">' + n + '</span></label>';
                }).join('');
            }

            // Guna globalStaffList dulu (ada paparTracker info), fallback ke outstationStaffNames
            if (globalStaffList.length > 0) {
                var visible = getVisibleStaffNames(globalStaffList);
                fillSelect(visible);
                fillChecklist(visible);
            } else if (outstationStaffNames.length > 0) {
                fillSelect(outstationStaffNames);
                fillChecklist(outstationStaffNames);
            } else {
                sel.disabled = true;
                sel.innerHTML = '<option value="">⏳ Memuatkan...</option>';
                callGAS("getStaffManagementData", {}, function(res) {
                    if (res.status === 'SUCCESS') { globalStaffList = res.data; }
                    var visible = getVisibleStaffNames(globalStaffList);
                    outstationStaffNames = visible;
                    fillSelect(visible);
                    fillChecklist(visible);
                });
            }
        }

