        function submitOutstationForm() {
            var btn = document.getElementById('btnSaveOutstation');
            btn.innerText = "Menyimpan...";
            btn.disabled = true;

            var rowVal = document.getElementById('ost_rowIndex').value;
            var commonFields = {
                tarikh: tarikh,
                autoClockIn: document.getElementById('ost_autoClockIn').checked,
                masaClockIn: document.getElementById('ost_masaClockIn').value,
                sebab: document.getElementById('ost_sebab').value.trim()
            };

            function onDone(res) {
                btn.innerText = "Simpan"; btn.disabled = false;
                if (res.status === 'SUCCESS') {
                    closeOutstationModal();
                    invalidateCache('outstationList');
                    loadOutstationList(true);
                } else { alert(res.message || "Gagal simpan."); }
            }

            if (rowVal) {
                // Edit mode — single staff, single date
                var nama = document.getElementById('ost_nama').value;
                var tarikh = document.getElementById('ost_tarikh').value;
                if (!nama || !tarikh) { btn.innerText = "Simpan"; btn.disabled = false; alert("Sila pilih nama staf dan tarikh."); return; }
                callGAS("saveOutstation", { payload: Object.assign({}, commonFields, { rowIndex: parseInt(rowVal), nama: nama, tarikh: tarikh }) }, onDone);
            } else {
                // Add mode — multiple staff, date range
                var dari = document.getElementById('ost_tarikhDari').value;
                var hingga = document.getElementById('ost_tarikhHingga').value;
                if (!dari || !hingga) { btn.innerText = "Simpan"; btn.disabled = false; alert("Sila pilih julat tarikh."); return; }
                if (dari > hingga) { btn.innerText = "Simpan"; btn.disabled = false; alert("Tarikh Dari mesti sebelum Tarikh Hingga."); return; }
                var checked = Array.from(document.querySelectorAll('#ost_staffChecklist .ost-staff-check:checked')).map(function(c) { return c.value; });
                if (checked.length === 0) { btn.innerText = "Simpan"; btn.disabled = false; alert("Sila pilih sekurang-kurangnya seorang staf."); return; }
                callGAS("saveOutstationBatch", { payload: Object.assign({}, commonFields, { staffNames: checked, tarikhDari: dari, tarikhHingga: hingga }) }, onDone);
            }
        }

        function deleteOutstationRecord(rowIndex) {
