        function loadLaporanLewat() {
            var monthVal = document.getElementById('llMonth').value;
            if (!monthVal) { alert("Sila pilih bulan."); return; }
            var parts = monthVal.split('-');
            var year = parseInt(parts[0]), month = parseInt(parts[1]);
            var staffName = document.getElementById('llStaffSelect').value;
            var cacheKey = (staffName || '__all__') + '|' + month + '|' + year;

            // Check cache dulu — instant
            var _lc = _qcGet('ll:' + cacheKey);
            if (_lc) { renderLaporanResult(_lc); return; }
            // Kalau pilih staff specific — check all-staff cache, filter client-side
            if (staffName) {
                var _allKey = '__all__|' + month + '|' + year;
                var _allCache = _qcGet('ll:' + _allKey);
                if (_allCache && _allCache.status === 'SUCCESS') {
                    var filtered = { status: 'SUCCESS', summary: { totalLewat: 0, totalMinit: 0, avgMinit: 0, lateStart: _allCache.summary.lateStart }, records: [] };
                    filtered.records = _allCache.records.filter(function(r) { return r.nama === staffName; });
                    filtered.summary.totalLewat = filtered.records.length;
                    filtered.summary.totalMinit = filtered.records.reduce(function(s,r){ return s + r.minitLewat; }, 0);
                    filtered.summary.avgMinit = filtered.records.length > 0 ? Math.round(filtered.summary.totalMinit / filtered.records.length) : 0;
                    _qcSet('ll:' + cacheKey, filtered);
                    renderLaporanResult(filtered); return;
                }
            }

            var tbody = document.getElementById('llTable');
            tbody.innerHTML = '<tr><td colspan="4" class="p-8 text-center text-yellow-500 animate-pulse">Menarik data...</td></tr>';
            document.getElementById('llSummary').classList.add('hidden');

            callGAS("getLaporanKelewatan", { staffName: staffName, month: month, year: year }, function(res) {
                _qcSet('ll:' + cacheKey, res);
                renderLaporanResult(res);
            });
        }

