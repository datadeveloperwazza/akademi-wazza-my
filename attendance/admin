        function renderCalendar(year, month) {
            var grid = document.getElementById('calendarGrid');
            grid.innerHTML = "";
            var firstDay = new Date(year, month, 1).getDay();
            var daysInMonth = new Date(year, month + 1, 0).getDate();
            var today = new Date();

            for (var i = 0; i < firstDay; i++) grid.innerHTML += '<div class="bg-transparent"></div>';

            for (var day = 1; day <= daysInMonth; day++) {
                var dateStr = year + "-" + String(month + 1).padStart(2, '0') + "-" + String(day).padStart(2, '0');
                var dayEvents = globalLeaveEvents.filter(function (e) { return e.start === dateStr; });
                var isToday = today.getDate() === day && today.getMonth() === month && today.getFullYear() === year;
                var ph = globalWorkConfig && globalWorkConfig.publicHolidays
                    ? globalWorkConfig.publicHolidays.find(function(h) { return h.date === dateStr; })
                    : null;

                var phHtml = ph
                    ? '<span class="event-badge bg-purple-950 text-purple-300 border border-purple-700"><span class="badge-text">🎌 ' + ph.name + '</span>' +
                      '<div class="tooltip-content"><strong class="block text-purple-300 text-xs mb-1">Cuti Umum</strong>' + ph.name + '<div class="tooltip-arrow"></div></div></span>'
                    : '';

