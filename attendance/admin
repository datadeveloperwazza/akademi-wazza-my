                    '<td class="p-3"><button onclick="openStaffDetailModal(\'' + safeName + '\')" class="font-semibold text-sm hover:text-yellow-400 text-white transition text-left">' + s.nama + '</button></td>' +
                    '<td class="p-3">' + badge + '</td>' +
                    '<td class="p-3 text-xs font-mono text-green-400">' + s.masaMasuk + '</td>' +
                    '<td class="p-3 text-xs font-mono text-yellow-400">' + s.masaKeluar + '</td>' +
                    '<td class="p-3">' + loc + '</td>' +
