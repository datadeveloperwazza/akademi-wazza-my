        function buildHistoryStatusBadge(status, cutiEvent, dateRaw) {
            if (status === 'HADIR') return '<span class="bg-green-900 text-green-300 px-2 py-0.5 rounded text-[10px] border border-green-700">HADIR</span>';
            if (status === 'LEWAT' || status === 'LEWAT (MANUAL)') return '<span class="bg-red-900 text-red-300 px-2 py-0.5 rounded text-[10px] border border-red-700">LEWAT</span>';
            if (String(status).includes('CUTI') || cutiEvent) {
                var jenis = cutiEvent ? cutiEvent.type : status.replace('CUTI - ', '');
                return '<span class="bg-yellow-900 text-yellow-300 px-2 py-0.5 rounded text-[10px] border border-yellow-700 uppercase">CUTI - ' + jenis + '</span>';
            }
            // TIDAK HADIR — semak cuti umum & hari rehat
            if (dateRaw) {
                var holiday = globalWorkConfig.publicHolidays.find(function(h) { return h.date === dateRaw; });
                if (holiday) return '<span class="bg-purple-900/60 text-purple-300 px-2 py-0.5 rounded text-[10px] border border-purple-700/60 uppercase">PH - ' + holiday.name + '</span>';
                if (globalWorkConfig.workDays.length > 0) {
                    var d = new Date(dateRaw + 'T00:00:00');
                    var dayNames = ['Ahad','Isnin','Selasa','Rabu','Khamis','Jumaat','Sabtu'];
                    var dayName = dayNames[d.getDay()];
                    if (!globalWorkConfig.workDays.some(function(wd) { return wd.toLowerCase() === dayName.toLowerCase(); })) {
                        return '<span class="bg-gray-800 text-gray-500 px-2 py-0.5 rounded text-[10px] border border-gray-700">REHAT</span>';
                    }
                }
            }
            return '<span class="bg-gray-700 text-gray-400 px-2 py-0.5 rounded text-[10px] border border-gray-600">ABSENT</span>';
        }

        function openStaffDetailModal(nama) {
            document.getElementById('staffDetailName').innerText = nama;
            var rangeEl = document.getElementById('staffDetailRange');
            var summaryEl = document.getElementById('staffDetailSummary');
            var tbody = document.getElementById('staffDetailTable');

            if (!globalHistoryData || globalHistoryData.length === 0) {
                rangeEl.innerText = 'Tiada data dimuatkan.';
                summaryEl.innerHTML = '';
                tbody.innerHTML = '<tr><td colspan="5" class="p-6 text-center text-gray-500">Sila cari rekod dahulu.</td></tr>';
            } else {
                var first = globalHistoryData[0].date;
                var last = globalHistoryData[globalHistoryData.length - 1].date;
                rangeEl.innerText = 'Julat: ' + (globalHistoryData.length === 1 ? first : first + ' — ' + last);

                var records = [];
                globalHistoryData.forEach(function(day) {
                    var rec = day.attendance.find(function(s) { return s.nama === nama; });
                    if (rec) records.push({ date: day.date, staff: rec, calendarEvents: day.calendarEvents });
                });

                var counts = { hadir: 0, lewat: 0, cuti: 0, absent: 0 };
                records.forEach(function(r) {
                    var st = r.staff.status;
                    var p2 = r.date.split('/');
                    var dateRaw = p2.length === 3 ? p2[2] + '-' + p2[1] + '-' + p2[0] : '';
                    if (st === 'HADIR') counts.hadir++;
                    else if (st === 'LEWAT' || st === 'LEWAT (MANUAL)') counts.lewat++;
                    else if (String(st).includes('CUTI')) counts.cuti++;
                    else {
                        var isOffDay = false;
                        if (dateRaw) {
                            if (globalWorkConfig.publicHolidays.find(function(h) { return h.date === dateRaw; })) {
                                isOffDay = true;
                            } else if (globalWorkConfig.workDays.length > 0) {
                                var d2 = new Date(dateRaw + 'T00:00:00');
                                var dayNames2 = ['Ahad','Isnin','Selasa','Rabu','Khamis','Jumaat','Sabtu'];
                                var dayName2 = dayNames2[d2.getDay()];
                                if (!globalWorkConfig.workDays.some(function(wd) { return wd.toLowerCase() === dayName2.toLowerCase(); })) {
                                    isOffDay = true;
                                }
                            }
                        }
                        if (!isOffDay) counts.absent++;
                    }
                });

                summaryEl.innerHTML =
                    '<div class="bg-green-900/30 border border-green-700/50 rounded-lg p-3 text-center"><div class="text-2xl font-bold text-green-400">' + counts.hadir + '</div><div class="text-[10px] text-gray-400 uppercase mt-1">Hadir</div></div>' +
                    '<div class="bg-red-900/30 border border-red-700/50 rounded-lg p-3 text-center"><div class="text-2xl font-bold text-red-400">' + counts.lewat + '</div><div class="text-[10px] text-gray-400 uppercase mt-1">Lewat</div></div>' +
                    '<div class="bg-yellow-900/30 border border-yellow-700/50 rounded-lg p-3 text-center"><div class="text-2xl font-bold text-yellow-400">' + counts.cuti + '</div><div class="text-[10px] text-gray-400 uppercase mt-1">Cuti</div></div>' +
                    '<div class="bg-gray-700/30 border border-gray-600/50 rounded-lg p-3 text-center"><div class="text-2xl font-bold text-gray-400">' + counts.absent + '</div><div class="text-[10px] text-gray-400 uppercase mt-1">Absent</div></div>';

                tbody.innerHTML = '';
                if (records.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="p-6 text-center text-gray-500">Tiada rekod untuk staf ini dalam tempoh ini.</td></tr>';
                } else {
                    records.forEach(function(r) {
                        var p2 = r.date.split('/');
                        var targetYMD = p2.length === 3 ? p2[2] + '-' + p2[1] + '-' + p2[0] : '';
