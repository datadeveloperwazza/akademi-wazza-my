        // Semak jenis hari: 'KERJA', 'REHAT', atau 'PH'
        function getDateType(dateRaw) {
            var ph = globalWorkConfig.publicHolidays.find(function(h) { return h.date === dateRaw; });
            if (ph) return { type: 'PH', holidayName: ph.name };
            if (globalWorkConfig.workDays.length > 0) {
                var d = new Date(dateRaw + 'T00:00:00');
                var dayNames = ['Ahad','Isnin','Selasa','Rabu','Khamis','Jumaat','Sabtu'];
                var dayName = dayNames[d.getDay()];
                var isWork = globalWorkConfig.workDays.some(function(wd) { return wd.toLowerCase() === dayName.toLowerCase(); });
                if (!isWork) return { type: 'REHAT', holidayName: null };
            }
            return { type: 'KERJA', holidayName: null };
        }

        function loadHistoryData() {
            var dateVal = document.getElementById('historyDateInput').value;
            if (!dateVal) { alert("Sila pilih tarikh dulu!"); return; }
            var btn = document.getElementById('btnSearchSingle');
            btn.innerText = "Mencari...";
            btn.disabled = true;
            globalHistoryData = [];

            // Semak jenis hari dulu
            var dayType = getDateType(dateVal);
            if (dayType.type !== 'KERJA') {
                var d = new Date(dateVal + 'T00:00:00');
                var dayNames = ['Ahad','Isnin','Selasa','Rabu','Khamis','Jumaat','Sabtu'];
                var p = dateVal.split('-');
                var dateStr = p[2] + '/' + p[1] + '/' + p[0];
                globalHistoryData = [{ dateRaw: dateVal, date: dateStr, dayType: dayType.type, holidayName: dayType.holidayName, attendance: [], calendarEvents: [] }];
                renderHistoryPage();
                btn.innerText = "Cari Rekod";
                btn.disabled = false;
                return;
            }

            // Guna cache kalau ada
            if (historyCache[dateVal] && (Date.now() - historyCache[dateVal].ts) < HISTORY_CACHE_TTL) {
                globalHistoryData = [historyCache[dateVal].data];
                renderHistoryPage();
                btn.innerText = "Cari Rekod";
                btn.disabled = false;
                return;
            }

            callGAS("getHistoryRange", { dates: [dateVal] }, function(res) {
                if (res.status === 'SUCCESS' && res.results.length > 0) {
                    var result = res.results[0];
                    historyCache[dateVal] = { data: result, ts: Date.now() };
                    globalHistoryData = [result];
                } else { globalHistoryData = []; }
                renderHistoryPage();
                btn.innerText = "Cari Rekod";
                btn.disabled = false;
            }, function() {
                btn.innerText = "Cari Rekod";
                btn.disabled = false;
                alert("Gagal memuatkan data.");
            });
        }

        function loadHistoryRange() {
            var fromVal = fpRangeStart;
            var toVal = fpRangeEnd;
            if (!fromVal || !toVal) { alert("Sila pilih julat tarikh dahulu!"); return; }
            var diffDays = Math.round((new Date(toVal + 'T00:00:00') - new Date(fromVal + 'T00:00:00')) / 86400000) + 1;
            if (diffDays > 14) { alert("Maksimum julat ialah 14 hari sahaja."); return; }

            var btn = document.getElementById('btnSearchRange');
            btn.innerText = "Mencari...";
            btn.disabled = true;
            globalHistoryData = [];

            // Jana senarai semua tarikh dalam julat
            var allDates = [];
            var cur = new Date(fromVal + 'T00:00:00');
            var end = new Date(toVal + 'T00:00:00');
            while (cur <= end) {
                allDates.push(cur.getFullYear() + '-' + String(cur.getMonth()+1).padStart(2,'0') + '-' + String(cur.getDate()).padStart(2,'0'));
                cur.setDate(cur.getDate() + 1);
            }

            // Asingkan setiap tarikh kepada 3 kategori
            var results = {};
            var toFetch = []; // tarikh kerja yang perlu GAS call

            allDates.forEach(function(dateRaw) {
                var dayType = getDateType(dateRaw);
                if (dayType.type !== 'KERJA') {
                    // Hari rehat/PH — placeholder, tiada GAS call
                    var p = dateRaw.split('-');
                    results[dateRaw] = { dateRaw: dateRaw, date: p[2]+'/'+p[1]+'/'+p[0], dayType: dayType.type, holidayName: dayType.holidayName, attendance: [], calendarEvents: [] };
                } else if (historyCache[dateRaw] && (Date.now() - historyCache[dateRaw].ts) < HISTORY_CACHE_TTL) {
                    results[dateRaw] = historyCache[dateRaw].data; // guna cache
                } else {
                    toFetch.push(dateRaw); // perlu fetch
                }
            });

            function finalize() {
                globalHistoryData = allDates.map(function(d) { return results[d]; }).filter(Boolean);
                renderHistoryPage();
                btn.innerText = "Cari Rekod";
                btn.disabled = false;
            }

            // Kalau tiada yang perlu di-fetch — terus render
            if (toFetch.length === 0) { finalize(); return; }

            // SATU GAS call untuk semua tarikh kerja yang belum dicache
            callGAS("getHistoryRange", { dates: toFetch }, function(res) {
                if (res.status === 'SUCCESS') {
                    res.results.forEach(function(r) {
                        historyCache[r.dateRaw] = { data: r, ts: Date.now() };
                        results[r.dateRaw] = r;
                    });
                }
                finalize();
            }, function() { finalize(); });
        }

        function getDayName(dateRaw) {
            var dayNames = ['Ahad', 'Isnin', 'Selasa', 'Rabu', 'Khamis', 'Jumaat', 'Sabtu'];
            return dayNames[new Date(dateRaw + 'T00:00:00').getDay()];
        }

        function buildScorecard() {
            var kerjaDays = globalHistoryData.filter(function(d) { return d.dayType !== 'REHAT' && d.dayType !== 'PH'; });
            if (kerjaDays.length === 0) return null;

            var totalHadir = 0, totalLewat = 0, totalCuti = 0, totalTidakHadir = 0;
            var totalKerja = kerjaDays.length;
            var staffSet = new Set();

            kerjaDays.forEach(function(day) {
                day.attendance.forEach(function(s) {
                    staffSet.add(s.nama);
                    var st = s.status.toUpperCase();
                    if (st === 'HADIR') totalHadir++;
                    else if (st === 'LEWAT') totalLewat++;
                    else if (st.indexOf('CUTI') === 0) totalCuti++;
                    else totalTidakHadir++;
                });
            });

            var totalStaff = staffSet.size;
            var totalSlot = totalKerja * totalStaff;
            var pct = totalSlot > 0 ? Math.round((totalHadir + totalLewat) / totalSlot * 100) : 0;
            var pctColor = pct >= 90 ? '#4ade80' : pct >= 70 ? '#eab308' : '#f87171';

            var el = document.createElement('div');
            el.innerHTML =
                '<p class="text-gray-500 text-xs uppercase font-bold mb-3">📊 Scorecard · ' + totalKerja + ' Hari Kerja</p>' +
                '<div class="grid grid-cols-2 md:grid-cols-5 gap-4">' +
                    '<div class="bg-gray-800 p-4 rounded-xl border-l-4 border-green-500">' +
                        '<p class="text-gray-500 text-xs uppercase font-bold">Hadir</p>' +
                        '<h2 class="text-3xl font-bold text-green-400 mt-1">' + totalHadir + '</h2>' +
                    '</div>' +
                    '<div class="bg-gray-800 p-4 rounded-xl border-l-4 border-red-500">' +
                        '<p class="text-gray-500 text-xs uppercase font-bold">Lewat</p>' +
                        '<h2 class="text-3xl font-bold text-red-400 mt-1">' + totalLewat + '</h2>' +
                    '</div>' +
                    '<div class="bg-gray-800 p-4 rounded-xl border-l-4 border-yellow-500">' +
                        '<p class="text-gray-500 text-xs uppercase font-bold">Cuti</p>' +
                        '<h2 class="text-3xl font-bold text-yellow-400 mt-1">' + totalCuti + '</h2>' +
                    '</div>' +
                    '<div class="bg-gray-800 p-4 rounded-xl border-l-4 border-gray-600">' +
                        '<p class="text-gray-500 text-xs uppercase font-bold">Tidak Hadir</p>' +
                        '<h2 class="text-3xl font-bold text-gray-400 mt-1">' + totalTidakHadir + '</h2>' +
                    '</div>' +
                    '<div class="bg-gray-800 p-4 rounded-xl border-l-4" style="border-left-color:' + pctColor + '">' +
                        '<p class="text-gray-500 text-xs uppercase font-bold">% Kehadiran</p>' +
                        '<h2 class="text-3xl font-bold mt-1" style="color:' + pctColor + '">' + pct + '%</h2>' +
                    '</div>' +
                '</div>';
            return el;
        }

        function renderHistoryPage() {
            var container = document.getElementById('historyResult');
            container.innerHTML = '';
            container.classList.remove('hidden');
            document.getElementById('historyEmptyState').classList.add('hidden');
            if (globalHistoryData.length === 0) {
                container.innerHTML = '<div class="text-gray-500 text-center py-8 bg-gray-800 rounded-xl border border-gray-700">Tiada data dijumpai.</div>';
                return;
            }

            // Scorecard di atas sekali
            var scorecard = buildScorecard();
            if (scorecard) container.appendChild(scorecard);

            globalHistoryData.forEach(function(dayData) {
                var div = document.createElement('div');

                // Hari Rehat atau Cuti Umum — tunjuk card compact sahaja, tiada table staf
                if (dayData.dayType === 'REHAT' || dayData.dayType === 'PH') {
                    var isPH = dayData.dayType === 'PH';
                    var label = isPH ? ('🎌 Cuti Umum — ' + (dayData.holidayName || '')) : '😴 Hari Rehat';
                    var borderColor = isPH ? 'border-purple-700' : 'border-gray-600';
