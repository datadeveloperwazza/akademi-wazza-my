                        '<div class="tooltip-content"><strong class="block text-yellow-400 text-xs mb-1">' + e.type + '</strong>' + e.title + '<div class="tooltip-arrow"></div></div></span>';
                }).join('');

                grid.innerHTML += '<div class="calendar-day ' + (isToday ? 'today' : '') + (ph ? ' bg-purple-950/20' : '') + '">' +
                    '<span class="day-number ' + (ph ? 'text-purple-400' : '') + '">' + day + '</span>' + phHtml + eventsHtml + '</div>';
