        function filterLeaveLog() {
            var textInput = document.getElementById('searchLeaveLog').value.toLowerCase();
            var dateInput = document.getElementById('dateLeaveLog').value;
            var sortType = document.getElementById('sortLeaveLog').value;
            var targetDateStr = "";
            if (dateInput) {
                var parts = dateInput.split("-");
                if (parts.length === 3) targetDateStr = parts[2] + "/" + parts[1] + "/" + parts[0];
            }
            var workingList = globalAllLeaveLog.filter(function (log) {
                var matchText = !textInput || (String(log.nama).toLowerCase().includes(textInput) || String(log.jenis).toLowerCase().includes(textInput) || String(log.sebab).toLowerCase().includes(textInput));
                var matchDate = !targetDateStr || log.tarikhCuti === targetDateStr;
                var matchStatus = leaveStatusFilter === 'SEMUA' || log.status === leaveStatusFilter;
                return matchText && matchDate && matchStatus;
            });
            workingList.sort(function (a, b) {
                if (sortType === 'cuti_desc') return b.sortTime - a.sortTime;
                if (sortType === 'cuti_asc') return a.sortTime - b.sortTime;
                if (sortType === 'mohon_desc') return parseTimestampToTime(b.timestamp) - parseTimestampToTime(a.timestamp);
                if (sortType === 'nama_asc') return a.nama.toUpperCase().localeCompare(b.nama.toUpperCase());
                return 0;
            });
            renderAllLeaveLogTable(workingList);
        }

        function parseTimestampToTime(timeStr) {
            if (!timeStr) return 0;
            var parts = timeStr.split(" ");
            if (parts.length < 2) return 0;
            var dPart = parts[0].split("/");
            var tPart = parts[1].split(":");
            if (dPart.length === 3 && tPart.length >= 2) return new Date(dPart[2], dPart[1] - 1, dPart[0], tPart[0], tPart[1]).getTime();
            return 0;
        }

