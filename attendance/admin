            // Folder & Geofencing
            document.getElementById('cfg_linkFolder').value = data.linkFolder || "";
            document.getElementById('cfg_officeLat').value = data.officeLat || "";
            document.getElementById('cfg_officeLng').value = data.officeLng || "";
            document.getElementById('cfg_officeRadius').value = data.officeRadius != null ? data.officeRadius : 0;

            // WFH Hari Tetap — tick checkbox yang berkenaan
            var dayMap = {
                'isnin': 'wfh_isnin', 'selasa': 'wfh_selasa', 'rabu': 'wfh_rabu',
                'khamis': 'wfh_khamis', 'jumaat': 'wfh_jumaat'
            };
            Object.keys(dayMap).forEach(function (day) {
                var el = document.getElementById(dayMap[day]);
                if (el) el.checked = data.wfhDays.map(function (d) { return d.toLowerCase(); }).includes(day);
            });

            // WFH Tarikh Override
            var today = new Date(); today.setHours(0,0,0,0);
            wfhDatesArray = Array.isArray(data.wfhDates)
                ? data.wfhDates.filter(function(d) { return new Date(d + 'T00:00:00') >= today; })
                : [];
            renderWfhDates();

            // Hari Bekerja
