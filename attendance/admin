                    div.innerHTML = '<span class="text-sm font-bold ' + textColor + '">📅 ' + getDayName(dayData.dateRaw) + ', ' + dayData.date + '</span>' +
                        '<span class="text-xs font-bold ' + textColor + ' uppercase tracking-wide">' + label + '</span>';
                    container.appendChild(div);
                    return;
                }

                // Hari Kerja — tunjuk table penuh
                var hadirCount = dayData.attendance.filter(function(s) {
                    var st = (s.status || '').toUpperCase();
                    return st === 'HADIR' || st === 'LEWAT';
                }).length;
                var totalCount = dayData.attendance.length;
                var pct = totalCount > 0 ? Math.round(hadirCount / totalCount * 100) : 0;
                var pctColor = pct >= 90 ? '#4ade80' : pct >= 70 ? '#eab308' : '#f87171';

                div.className = 'bg-gray-800 rounded-xl border border-gray-700 overflow-hidden shadow-xl';
                div.innerHTML =
                    '<div class="p-4 border-b border-gray-700 font-bold text-white flex items-center justify-between">' +
                    '<span>📅 ' + getDayName(dayData.dateRaw) + ', ' + dayData.date + '</span>' +
                    '<div class="flex items-center gap-2">' +
                    '<span class="text-xs text-gray-400 font-normal">' + totalCount + ' staf</span>' +
                    '<span style="background:' + pctColor + '22; color:' + pctColor + '; border:1px solid ' + pctColor + '55;" class="text-xs font-bold px-2 py-0.5 rounded-full">' + pct + '%</span>' +
                    '</div>' +
                    '</div>' +
                    '<div class="overflow-x-auto"><table class="w-full text-left text-sm">' +
