    <!-- ===== SCRIPTS ===== -->
    <script>
        // ===== CONFIG — isi sebelum deploy =====
        const GAS_URL = "https://script.google.com/macros/s/AKfycbzjwycP8S7eGC_dLML24louH75mM9pOsVxDhTJJ8qE_qSgzPcCKHJhd9hzilAaaMaoT/exec";
        const WEBSITE_URL = "https://urus.wazza.my"; // tiada trailing slash
        // =======================================

        function callGAS(action, params, onSuccess, onError) {
            const url = GAS_URL + "?data=" + encodeURIComponent(JSON.stringify(Object.assign({ action: action }, params || {})));
            fetch(url)
            .then(function(res) {
                if (!res.ok) throw new Error("HTTP " + res.status);
                return res.json();
            })
            .then(function(data) { if (onSuccess) onSuccess(data); })
            .catch(function(err) {
                if (onError) onError(err);
                else console.error("callGAS error:", action, err);
            });
        }

        // ==========================================
        // ADMIN LOGIN
        // ==========================================
        window.addEventListener('DOMContentLoaded', function () {
            var adminToken = localStorage.getItem('wazza_admin_access');
            if (adminToken === 'VERIFIED') {
                unlockDashboard();
            }
        });

        function handleAdminLogin() {
            var btn = document.getElementById('btnAdminLogin');
            var errDiv = document.getElementById('loginError');
            var u = document.getElementById('loginUser').value.trim();
            var p = document.getElementById('loginPass').value;

            if (!u || !p) {
                errDiv.innerText = "Sila isi semua maklumat.";
                errDiv.classList.remove('hidden');
                return;
            }

            errDiv.classList.add('hidden');
            btn.innerText = "MENYEMAK...";
            btn.disabled = true;

            callGAS("verifyAdminLogin", { username: u, password: p }, function (res) {
                if (res.status === 'SUCCESS') {
                    localStorage.setItem('wazza_admin_access', 'VERIFIED');
                    unlockDashboard();
                } else {
                    errDiv.innerText = res.message || 'Akses ditolak.';
                    errDiv.classList.remove('hidden');
                    btn.innerText = "Akses Dashboard";
                    btn.disabled = false;
                    document.getElementById('loginPass').value = "";
                }
            }, function (err) {
                errDiv.innerText = "Ralat sistem: " + err.message;
                errDiv.classList.remove('hidden');
                btn.innerText = "Akses Dashboard";
                btn.disabled = false;
            });
        }

        function unlockDashboard() {
            document.getElementById('adminLoginOverlay').style.display = "none";
            var wrapper = document.getElementById('mainDashboardWrapper');
            wrapper.classList.remove('hidden');
            setTimeout(function () {
                wrapper.classList.remove('opacity-0');
                wrapper.classList.add('opacity-100');
            }, 50);
            // Set nav & page state terus (tanpa fetch data)
            document.querySelectorAll('.nav-item').forEach(function(el) { el.classList.remove('active'); });
            var navEl = document.getElementById('nav-dashboard');
            if (navEl) navEl.classList.add('active');
            allPages.forEach(function(p) { var el = document.getElementById('page-' + p); if (el) el.classList.add('hidden'); });
            document.getElementById('page-dashboard').classList.remove('hidden');
            updateMonthPickerInput();
            _qcLoad(); // restore query cache dari localStorage
            initCacheAndLoad(); // Parallel fetch semua data sekaligus
        }

        function logoutAdmin() {
            if (confirm("Pasti untuk log keluar dari Admin Dashboard?")) {
                localStorage.removeItem('wazza_admin_access');
                location.reload();
            }
        }

        // ==========================================
        // PAGE NAVIGATION
        // ==========================================
        var currentMonth = new Date().getMonth();
        var currentYear = new Date().getFullYear();
        var globalLeaveEvents = [];
        var globalAllLeaveLog = [];
        var globalStaffList = [];
        var staffStatusFilter = 'AKTIF';
        var leaveStatusFilter = 'DILULUSKAN';
        var globalHistoryData = [];
        var currentHistoryMode = 'single';
        var HISTORY_CACHE_TTL = 60 * 60 * 1000;
        // historyCache — wrapper ke _qStore supaya persist across refresh
        var historyCache = new Proxy({}, {
            get: function(t, k) {
                if (t[k]) return t[k];
                var v = _qcGet('hist:' + k);
                if (v) { t[k] = v; return v; }
                return undefined;
            },
            set: function(t, k, v) {
                t[k] = v;
                _qcSet('hist:' + k, v);
                return true;
            }
        });
        var allPages = ['dashboard', 'history', 'leave', 'allLeaveLog', 'staff', 'outstation', 'laporanLewat', 'suratAmaran', 'config'];

        // ==========================================
        // CACHE SYSTEM — in-memory + localStorage (Looker Studio style)
        // ==========================================
        var CACHE_TTL = 15 * 60 * 1000;
        var ADMIN_CACHE_VER = 'av2';
        var LS_KEY = 'wazza_admin_cache';

        // ── Query cache (Laporan Kelewatan, Surat Amaran, Leave Balance) ──
        // In-memory + localStorage, TTL 15 minit
        var _qStore = {};
        var _qLsKey = 'wazza_qcache';

        function _qcLoad() {
            try {
                var raw = localStorage.getItem(_qLsKey);
                if (!raw) return;
                var obj = JSON.parse(raw);
                if (obj.ver !== ADMIN_CACHE_VER) { localStorage.removeItem(_qLsKey); return; }
                var now = Date.now();
                Object.keys(obj.d).forEach(function(k) {
                    if (now - obj.d[k].ts < CACHE_TTL) _qStore[k] = obj.d[k];
                });
            } catch(e) {}
        }
        function _qcGet(key) {
            var e = _qStore[key];
            if (!e || Date.now() - e.ts > CACHE_TTL) { if (e) { delete _qStore[key]; _qcSave(); } return null; }
            return e.data;
        }
        function _qcSet(key, data) {
            _qStore[key] = { ts: Date.now(), data: data };
            _qcSave();
        }
        function _qcDel(key) { delete _qStore[key]; _qcSave(); }
        function _qcSave() {
            try { localStorage.setItem(_qLsKey, JSON.stringify({ ver: ADMIN_CACHE_VER, d: _qStore })); } catch(e) {}
        }

        var appCache = {
            dashboard:         { data: null, ts: 0 },
            allLeaveLog:       { data: null, ts: 0 },
            staffManagement:   { data: null, ts: 0 },
            outstationList:    { data: null, ts: 0 },
            outstationTrigger: { data: null, ts: 0 },
            staffList:         { data: null, ts: 0 },
            config:            { data: null, ts: 0 }
        };
        var autoRefreshIntervalId = null;
        var countdownIntervalId = null;
        var nextRefreshTs = 0;

        function isCacheValid(key) {
            return appCache[key] && appCache[key].data !== null && (Date.now() - appCache[key].ts) < CACHE_TTL;
        }
        function setCache(key, data) {
            if (appCache[key]) { appCache[key].data = data; appCache[key].ts = Date.now(); }
            _persistCache();
        }
        function invalidateCache(key) {
            if (appCache[key]) appCache[key].ts = 0;
        }

        function _persistCache() {
            try {
                var snapshot = {};
                Object.keys(appCache).forEach(function(k) {
                    if (appCache[k].data !== null) snapshot[k] = { data: appCache[k].data, ts: appCache[k].ts };
                });
                localStorage.setItem(LS_KEY, JSON.stringify({ ver: ADMIN_CACHE_VER, snapshot: snapshot }));
            } catch(e) {}
        }

        function _loadCacheFromLS() {
            try {
                var raw = localStorage.getItem(LS_KEY);
                if (!raw) return false;
                var obj = JSON.parse(raw);
                if (obj.ver !== ADMIN_CACHE_VER) { localStorage.removeItem(LS_KEY); return false; }
                var anyValid = false;
                Object.keys(obj.snapshot).forEach(function(k) {
                    if (appCache[k] && obj.snapshot[k].data !== null) {
                        appCache[k].data = obj.snapshot[k].data;
                        appCache[k].ts = obj.snapshot[k].ts;
                        if ((Date.now() - obj.snapshot[k].ts) < CACHE_TTL) anyValid = true;
                    }
                });
                return anyValid;
            } catch(e) { return false; }
        }

        // Render dari cache yang ada (untuk page load terus)
        function renderFromCache() {
            if (isCacheValid('config') && appCache.config.data) {
                var wd = Array.isArray(appCache.config.data.workDays) && appCache.config.data.workDays.length > 0 ? appCache.config.data.workDays : ['Isnin','Selasa','Rabu','Khamis','Jumaat'];
                globalWorkConfig = { workDays: wd, publicHolidays: Array.isArray(appCache.config.data.publicHolidays) ? appCache.config.data.publicHolidays : [] };
            }
            if (isCacheValid('dashboard')) {
                var d = appCache.dashboard.data;
                globalLeaveEvents = d.calendarEvents || [];
                renderDashboard(d);
                // Re-render calendar dengan PH yang betul sekarang config dah loaded
                renderCalendar(currentYear, currentMonth);
            }
            if (isCacheValid('staffManagement') && appCache.staffManagement.data) {
                globalStaffList = appCache.staffManagement.data;
            }
            if (isCacheValid('staffList') && appCache.staffList.data) {
                outstationStaffNames = appCache.staffList.data;
            }
        }

        // Helper: fetch laporan + surat untuk 1 bulan dan simpan ke qcache
        function _prefetchMonth(month, year) {
            var llKey = '__all__|' + month + '|' + year;
            var saKey = month + '|' + year;
            if (!_qcGet('ll:' + llKey)) {
                callGAS("getLaporanKelewatan", { staffName: '', month: month, year: year }, function(res) {
                    _qcSet('ll:' + llKey, res);
                });
            }
            if (!_qcGet('sa:' + saKey)) {
                callGAS("getWarningReport", { month: month, year: year }, function(res) {
                    _qcSet('sa:' + saKey, res);
                });
            }
        }

        // Background prefetch: 3 bulan sebelumnya, satu persatu senyap
        function _backgroundPrefetch3Months() {
            var now = new Date();
            var months = [];
            for (var i = 1; i <= 3; i++) {
                var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
                months.push({ month: d.getMonth() + 1, year: d.getFullYear() });
            }
            // Sequential — satu bulan habis baru start yang lain, avoid overwhelming GAS
            function fetchNext(idx) {
                if (idx >= months.length) return;
                var m = months[idx];
                var llKey = '__all__|' + m.month + '|' + m.year;
                var saKey = m.month + '|' + m.year;
                var done = 0;
                function next() { done++; if (done >= 2) fetchNext(idx + 1); }
                if (!_qcGet('ll:' + llKey)) {
                    callGAS("getLaporanKelewatan", { staffName: '', month: m.month, year: m.year }, function(res) { _qcSet('ll:' + llKey, res); next(); }, next);
                } else { next(); }
                if (!_qcGet('sa:' + saKey)) {
                    callGAS("getWarningReport", { month: m.month, year: m.year }, function(res) { _qcSet('sa:' + saKey, res); next(); }, next);
                } else { next(); }
            }
            fetchNext(0);
        }

        // Fetch semua data baru (background atau first load)
        function fetchAllData(onComplete) {
            var done = 0; var total = 6;
            function tick() { done++; if (done >= total && onComplete) onComplete(); }
            callGAS("getAdminDashboardData", {}, function(data) {
                setCache('dashboard', data);
                globalLeaveEvents = data.calendarEvents || [];
                var dashPage = document.getElementById('page-dashboard');
                if (dashPage && !dashPage.classList.contains('hidden')) renderDashboard(data);
                tick();
            }, tick);
            callGAS("getAllLeaveLog", {}, function(data) { setCache('allLeaveLog', data); tick(); }, tick);
            callGAS("getStaffManagementData", {}, function(res) {
                if (res.status === 'SUCCESS') { setCache('staffManagement', res.data); globalStaffList = res.data; }
                tick();
            }, tick);
            callGAS("getSystemConfig", {}, function(res) {
                if (res.status === 'SUCCESS') {
                    setCache('config', res.data);
                    var wd = Array.isArray(res.data.workDays) && res.data.workDays.length > 0 ? res.data.workDays : ['Isnin','Selasa','Rabu','Khamis','Jumaat'];
                    globalWorkConfig = { workDays: wd, publicHolidays: Array.isArray(res.data.publicHolidays) ? res.data.publicHolidays : [] };
                }
                tick();
            }, tick);
            callGAS("getStaffList", {}, function(names) {
                var list = Array.isArray(names) ? names : [];
                setCache('staffList', list);
                outstationStaffNames = list;
                tick();
            }, tick);
            callGAS("getOutstationList", {}, function(res) {
                if (res.status === 'SUCCESS') setCache('outstationList', res.data);
                tick();
            }, tick);
        }

        // Init — check localStorage dulu, kalau ada render terus, fetch background
        function initCacheAndLoad() {
            var hasCache = _loadCacheFromLS();
            if (hasCache) {
                // Ada cache — render terus, fetch background senyap
                renderFromCache();
                document.getElementById('loaderLive').classList.add('hidden');
                fetchAllData(function() {
                    startAutoRefresh();
                });
            } else {
                // Takda cache — show loader, fetch, render
                document.getElementById('loaderLive').classList.remove('hidden');
                fetchAllData(function() {
                    renderFromCache();
                    document.getElementById('loaderLive').classList.add('hidden');
                    startAutoRefresh();
                });
            }
        }

        // Mulakan auto-refresh 15 minit + countdown timer
        function startAutoRefresh() {
            if (autoRefreshIntervalId) clearInterval(autoRefreshIntervalId);
            if (countdownIntervalId) clearInterval(countdownIntervalId);
            nextRefreshTs = Date.now() + CACHE_TTL;
            updateCacheStatusBar();
            document.getElementById('cacheStatusBar').classList.remove('hidden');
            autoRefreshIntervalId = setInterval(refreshAllCache, CACHE_TTL);
            countdownIntervalId = setInterval(updateCacheStatusBar, 1000);
        }

        // Auto-refresh background — update semua cache
        function refreshAllCache() {
            nextRefreshTs = Date.now() + CACHE_TTL;
            updateCacheStatusBar();
            fetchAllData(function() {
                // Re-render page yang sedang aktif
                var logPage = document.getElementById('page-allLeaveLog');
                if (logPage && !logPage.classList.contains('hidden')) { globalAllLeaveLog = appCache.allLeaveLog.data || []; filterLeaveLog(); }
                updateCacheStatusBar();
            });
        }

        // Manual refresh dari button dashboard — refresh dashboard + leave log
        function manualRefreshAll() {
            var btn = document.getElementById('btnManualRefresh');
            btn.innerText = "⏳ Memuatkan...";
            btn.disabled = true;
            invalidateCache('dashboard');
            invalidateCache('allLeaveLog');
            if (autoRefreshIntervalId) clearInterval(autoRefreshIntervalId);
            var btnDone = false;
            callGAS("getAdminDashboardData", {}, function(data) {
                setCache('dashboard', data);
                globalLeaveEvents = data.calendarEvents || [];
                renderDashboard(data);
                if (!btnDone) { btnDone = true; btn.innerText = "🔄 Refresh Sekarang"; btn.disabled = false; }
                nextRefreshTs = Date.now() + CACHE_TTL;
                autoRefreshIntervalId = setInterval(refreshAllCache, CACHE_TTL);
                updateCacheStatusBar();
            }, function() {
                if (!btnDone) { btnDone = true; btn.innerText = "🔄 Refresh Sekarang"; btn.disabled = false; }
            });
            callGAS("getAllLeaveLog", {}, function(data) {
                setCache('allLeaveLog', data);
                var logPage = document.getElementById('page-allLeaveLog');
                if (logPage && !logPage.classList.contains('hidden')) { globalAllLeaveLog = data; filterLeaveLog(); }
            });
        }

        // Update UI: masa terakhir dikemaskini + countdown timer
        function updateCacheStatusBar() {
            var lastTime = document.getElementById('lastUpdatedTime');
            var countdown = document.getElementById('countdownTimer');
            if (!lastTime || !countdown) return;
            if (appCache.dashboard.ts > 0) {
                var d = new Date(appCache.dashboard.ts);
                lastTime.innerText = String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
            }
            var rem = Math.max(0, nextRefreshTs - Date.now());
            countdown.innerText = Math.floor(rem / 60000) + ':' + String(Math.floor((rem % 60000) / 1000)).padStart(2,'0');
        }

        function switchPage(page) {
            document.querySelectorAll('.nav-item').forEach(function (el) {
                el.classList.remove('active');
            });
            var navEl = document.getElementById('nav-' + page);
            if (navEl) navEl.classList.add('active');

            allPages.forEach(function (p) {
                var el = document.getElementById('page-' + p);
                if (el) el.classList.add('hidden');
            });

            var target = document.getElementById('page-' + page);
            if (target) target.classList.remove('hidden');

