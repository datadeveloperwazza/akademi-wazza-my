        function renderHistoryRows(tbodyId, list, dateStr, leaveEvents) {
            var tbody = document.getElementById(tbodyId);
            if (!tbody) return;
            tbody.innerHTML = '';
            if (!list || list.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="p-6 text-center text-gray-500">Tiada rekod.</td></tr>';
                return;
            }
            var targetYMD = '';
            if (dateStr) {
                var p = dateStr.split('/');
                if (p.length === 3) targetYMD = p[2] + '-' + p[1] + '-' + p[0];
            }
            list.forEach(function(s) {
                var cutiEvent = (targetYMD && leaveEvents) ? leaveEvents.find(function(e) { return e.start === targetYMD && e.title === s.nama; }) : null;
                var badge = buildHistoryStatusBadge(s.status, cutiEvent, targetYMD);
