<!DOCTYPE html>
<html lang="ms">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ms.js"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .loading-pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: .5;
            }
        }

        .nav-item.active {
            background-color: #fbbf24;
            color: #111827;
            font-weight: bold;
        }

        input[type="date"]::-webkit-calendar-picker-indicator,
        input[type="month"]::-webkit-calendar-picker-indicator {
            filter: invert(1);
            cursor: pointer;
        }

        /* CALENDAR STYLES */
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 4px;
            height: 100%;
        }

        .calendar-day {
            min-height: 100px;
            background: #1f2937;
            padding: 8px;
            border-radius: 8px;
            border: 1px solid #374151;
            position: relative;
            overflow: visible;
            min-width: 0;
        }

        .calendar-header {
            font-weight: bold;
            text-align: center;
            color: #9ca3af;
            font-size: 0.85rem;
            padding-bottom: 8px;
            text-transform: uppercase;
        }

        /* TOOLTIP STYLES */
        .event-badge {
            font-size: 0.7rem;
            padding: 3px 6px;
            border-radius: 4px;
            margin-top: 4px;
            overflow: visible;
            display: block;
            font-weight: 600;
            box-shadow: 0 2px 2px rgba(0, 0, 0, 0.2);
            position: relative;
            cursor: pointer;
            transition: all 0.2s;
        }

        .event-badge .badge-text {
            display: block;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .event-badge:hover {
            z-index: 100;
        }

        .event-badge:hover .tooltip-content {
            visibility: visible;
            opacity: 1;
            bottom: 110%;
        }

        .tooltip-content {
            visibility: hidden;
            opacity: 0;
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            background-color: #000000;
            color: #fff;
            text-align: center;
            border: 1px solid #fbbf24;
            padding: 8px;
            border-radius: 6px;
            z-index: 999;
            width: max-content;
            max-width: 200px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
            transition: opacity 0.2s;
            white-space: normal;
            pointer-events: none;
        }

        .tooltip-arrow {
            position: absolute;
            top: 100%;
            left: 50%;
            margin-left: -5px;
            border-width: 5px;
            border-style: solid;
            border-color: #fbbf24 transparent transparent transparent;
        }

        .day-number {
            font-size: 1.2rem;
            font-weight: bold;
            color: #6b7280;
            position: absolute;
            top: 5px;
            right: 10px;
        }

        .today .day-number {
            color: #fbbf24;
        }

        .today {
            border: 2px solid #fbbf24;
            background: #374151;
        }

        /* FADE IN ANIMATION */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: scale(0.95);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .animate-fade-in {
            animation: fadeIn 0.3s ease-out forwards;
        }

        /* CONFIG INPUT STYLES */
        .cfg-input {
            background: #111827;
            border: 1px solid #374151;
            color: white;
            padding: 10px 12px;
            border-radius: 8px;
            width: 100%;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .cfg-input:focus {
            border-color: #fbbf24;
            box-shadow: 0 0 0 1px #fbbf24;
        }

        .cfg-label {
            display: block;
            font-size: 0.7rem;
            font-weight: 700;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 6px;
        }

        .cfg-card {
            background: #1f2937;
            padding: 24px;
            border-radius: 16px;
            border: 1px solid #374151;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2);
        }

        .wfh-day-label {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #111827;
            padding: 8px 12px;
            border-radius: 8px;
            border: 1px solid #374151;
            cursor: pointer;
            transition: border-color 0.2s;
            user-select: none;
        }

        .wfh-day-label:hover {
            border-color: #fbbf24;
        }

        .wfh-day-label input:checked+span {
            color: #fbbf24;
            font-weight: 700;
        }

        .wfh-day-label:has(input:checked) {
            border-color: #fbbf24;
            background: rgba(251, 191, 36, 0.08);
        }
        /* Hide scrollbar tapi masih boleh scroll */
        .sidebar-nav { scrollbar-width: none; -ms-overflow-style: none; }
        .sidebar-nav::-webkit-scrollbar { display: none; }
        /* Nav group collapsed */
        .nav-group-collapsed { max-height: 0 !important; }
        /* Flatpickr dark theme */
        .flatpickr-calendar { background:#1f2937; border:1px solid #374151; box-shadow:0 12px 40px rgba(0,0,0,0.6); border-radius:12px; font-family:inherit; }
        .flatpickr-months { background:#111827; border-radius:12px 12px 0 0; padding:2px 0; }
        .flatpickr-month { color:#f9fafb; fill:#f9fafb; }
        .flatpickr-current-month { color:#f9fafb; font-weight:700; }
        .flatpickr-current-month .flatpickr-monthDropdown-months { background:#111827; color:#f9fafb; border:none; font-weight:700; appearance:none; -webkit-appearance:none; }
        .flatpickr-current-month .flatpickr-monthDropdown-months option { background:#1f2937; color:#f9fafb; }
        .flatpickr-current-month input.cur-year { color:#f9fafb; font-weight:700; }
        .numInputWrapper span { border-color:#374151; }
        .numInputWrapper span svg path { fill:#9ca3af; }
        .flatpickr-calendar .flatpickr-prev-month, .flatpickr-calendar .flatpickr-next-month { fill:#d1d5db !important; color:#d1d5db !important; }
        .flatpickr-calendar .flatpickr-prev-month:hover, .flatpickr-calendar .flatpickr-next-month:hover { fill:#fbbf24 !important; color:#fbbf24 !important; background:rgba(251,191,36,0.1); border-radius:6px; }
        .flatpickr-calendar .flatpickr-prev-month svg, .flatpickr-calendar .flatpickr-next-month svg { fill:inherit !important; }
        .flatpickr-innerContainer { border-top:1px solid #374151; }
        .flatpickr-rContainer { padding:4px; }
        .flatpickr-weekdays { background:#111827; }
        .flatpickr-calendar .flatpickr-weekdays .flatpickr-weekday { background:#111827 !important; color:#d1d5db !important; font-weight:700 !important; font-size:11px !important; }
        .flatpickr-days { border-color:#374151; }
        .dayContainer { padding:4px; gap:2px; }
        .flatpickr-day { color:#d1d5db; border-radius:6px; border:none; font-size:13px; }
        .flatpickr-day:hover, .flatpickr-day:focus { background:#374151; border-color:#374151; color:#fff; }
        .flatpickr-day.selected, .flatpickr-day.startRange, .flatpickr-day.endRange { background:#eab308 !important; border-color:#eab308 !important; color:#000 !important; font-weight:700; }
        .flatpickr-day.selected:hover, .flatpickr-day.startRange:hover, .flatpickr-day.endRange:hover { background:#fbbf24 !important; border-color:#fbbf24 !important; }
        .flatpickr-day.inRange { background:#78350f; border-color:#78350f; color:#fde68a; box-shadow:-5px 0 0 #78350f, 5px 0 0 #78350f; border-radius:0; }
        .flatpickr-day.startRange { border-radius:6px 0 0 6px; }
        .flatpickr-day.endRange { border-radius:0 6px 6px 0; }
        .flatpickr-day.startRange.endRange { border-radius:6px; }
        .flatpickr-day.today { border-color:#4b5563 !important; color:#fbbf24; }
        .flatpickr-day.today:hover { background:#374151; color:#fbbf24; }
        .flatpickr-day.flatpickr-disabled, .flatpickr-day.flatpickr-disabled:hover { color:#374151; background:transparent; cursor:not-allowed; }
        .flatpickr-day.prevMonthDay, .flatpickr-day.nextMonthDay { color:#4b5563; }
    </style>
</head>

<body class="bg-gray-900 text-gray-100 h-screen overflow-hidden relative">

    <!-- ===== LOGIN OVERLAY ===== -->
    <div id="adminLoginOverlay" class="fixed inset-0 bg-gray-900 z-[999] flex flex-col items-center justify-center p-4">
        <div class="bg-gray-800 p-8 rounded-3xl shadow-2xl border border-gray-700 w-full max-w-sm animate-fade-in">
            <div class="text-center mb-8">
                <div class="inline-block bg-yellow-500/10 p-4 rounded-full mb-4">
                    <span class="text-4xl">🔐</span>
                </div>
                <h1 class="text-2xl font-black tracking-widest text-white">WAZZA<span
                        class="text-yellow-500">ADMIN</span></h1>
                <p class="text-xs text-gray-400 mt-1 uppercase tracking-widest">Kawasan Kawalan Keselamatan</p>
            </div>
            <div class="space-y-5">
                <div>
                    <label class="block text-gray-400 text-xs font-bold mb-2 uppercase">ID Pengguna</label>
                    <input type="text" id="loginUser" required
                        class="w-full p-3 bg-gray-900 border border-gray-600 text-white rounded-xl focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition">
                </div>
                <div>
                    <label class="block text-gray-400 text-xs font-bold mb-2 uppercase">Kata Laluan</label>
                    <input type="password" id="loginPass" required
                        class="w-full p-3 bg-gray-900 border border-gray-600 text-white rounded-xl focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500 transition"
                        onkeydown="if(event.key==='Enter') handleAdminLogin()">
                </div>
                <div id="loginError"
                    class="hidden text-red-400 text-xs text-center font-bold bg-red-900/30 border border-red-800 rounded-lg p-2">
                </div>
                <button onclick="handleAdminLogin()" id="btnAdminLogin"
                    class="w-full bg-yellow-600 hover:bg-yellow-500 text-gray-900 font-black py-3 rounded-xl shadow-lg transition tracking-widest uppercase mt-4">
                    Akses Dashboard
                </button>
            </div>
        </div>
    </div>

    <!-- ===== MAIN DASHBOARD ===== -->
    <div id="mainDashboardWrapper" class="h-full flex hidden opacity-0 transition-opacity duration-500">

        <!-- SIDEBAR -->
        <aside class="w-64 bg-gray-800 border-r border-gray-700 flex-col hidden md:flex flex-shrink-0">
            <div class="h-20 flex items-center justify-center border-b border-gray-700">
                <h1 class="font-bold text-xl tracking-wide">WAZZA<span class="text-yellow-500">ADMIN</span></h1>
            </div>
            <nav class="flex-1 p-3 space-y-1 overflow-y-auto sidebar-nav">
                <button onclick="switchPage('dashboard')" id="nav-dashboard"
                    class="nav-item active w-full flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition text-sm">
                    <span>🏠</span> Dashboard Utama
                </button>

                <p class="text-[10px] font-bold text-gray-600 uppercase tracking-widest px-3 pt-3 pb-1">Rekod</p>
                <button onclick="switchPage('history')" id="nav-history"
                    class="nav-item w-full flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition text-sm">
                    <span>📜</span> Rekod Terdahulu
                </button>
                <button onclick="switchPage('laporanLewat')" id="nav-laporanLewat"
                    class="nav-item w-full flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition text-sm">
                    <span>⏰</span> Laporan Kelewatan
                </button>

                <p class="text-[10px] font-bold text-gray-600 uppercase tracking-widest px-3 pt-3 pb-1">Cuti</p>
                <button onclick="switchPage('leave')" id="nav-leave"
                    class="nav-item w-full flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition text-sm">
                    <span>🗓️</span> Laporan Cuti
                </button>
                <button onclick="switchPage('allLeaveLog')" id="nav-allLeaveLog"
                    class="nav-item w-full flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition text-sm">
                    <span>📂</span> Senarai Cuti
                </button>

                <p class="text-[10px] font-bold text-gray-600 uppercase tracking-widest px-3 pt-3 pb-1">Pengurusan</p>
                <button onclick="switchPage('staff')" id="nav-staff"
                    class="nav-item w-full flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition text-sm">
                    <span>👥</span> Pengurusan Staf
                </button>
                <button onclick="switchPage('outstation')" id="nav-outstation"
                    class="nav-item w-full flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition text-sm">
                    <span>🗺️</span> Outstation
                </button>

                <p class="text-[10px] font-bold text-gray-600 uppercase tracking-widest px-3 pt-3 pb-1">Sistem</p>
                <button onclick="switchPage('suratAmaran')" id="nav-suratAmaran"
                    class="nav-item w-full flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition text-sm">
                    <span>📄</span> Surat Amaran
                </button>
                <button onclick="switchPage('config')" id="nav-config"
                    class="nav-item w-full flex items-center gap-3 px-3 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-gray-700 transition text-sm">
                    <span>⚙️</span> Tetapan Sistem
                </button>
            </nav>
            <div class="px-4 py-3 border-t border-gray-700">
                <button onclick="manualRefreshAll()" id="btnManualRefresh"
                    class="w-full bg-yellow-600 hover:bg-yellow-500 text-white px-3 py-2 rounded-lg text-xs font-bold shadow flex items-center justify-center gap-2 transition">
                    🔄 Refresh Sekarang
                </button>
                <div id="cacheStatusBar" class="hidden text-[10px] text-gray-500 text-center mt-2 space-y-0.5">
                    <div>Dikemaskini: <span id="lastUpdatedTime" class="text-gray-400 font-mono">—</span></div>
                    <div>Auto-refresh: <span id="countdownTimer" class="text-yellow-500 font-mono font-bold">15:00</span></div>
                </div>
            </div>
            <div class="px-4 pb-4 border-t border-gray-700 pt-3">
                <button onclick="logoutAdmin()"
                    class="flex items-center gap-2 text-xs font-bold text-red-400 hover:text-red-300 bg-gray-900 py-2 px-4 rounded-lg border border-red-900/50 w-full justify-center transition">
                    Keluar Sistem
                </button>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="flex-1 flex flex-col h-full overflow-hidden relative min-w-0">

            <!-- MOBILE HEADER -->
            <header
                class="md:hidden bg-gray-800 border-b border-gray-700 p-4 flex justify-between items-center flex-shrink-0">
                <h1 class="font-bold text-lg">WAZZA<span class="text-yellow-500">ADMIN</span></h1>
                <div class="flex gap-1 items-center flex-wrap">
                    <button onclick="switchPage('dashboard')" class="bg-gray-700 p-2 rounded text-xs">🏠</button>
                    <button onclick="switchPage('history')" class="bg-gray-700 p-2 rounded text-xs">📜</button>
                    <button onclick="switchPage('leave')" class="bg-gray-700 p-2 rounded text-xs">🗓️</button>
                    <button onclick="switchPage('allLeaveLog')" class="bg-gray-700 p-2 rounded text-xs">📂</button>
                    <button onclick="switchPage('staff')" class="bg-gray-700 p-2 rounded text-xs">👥</button>
                    <button onclick="switchPage('outstation')" class="bg-gray-700 p-2 rounded text-xs">🗺️</button>
                    <button onclick="switchPage('config')" class="bg-gray-700 p-2 rounded text-xs">⚙️</button>
                    <button onclick="logoutAdmin()"
                        class="bg-red-900/50 text-red-400 p-2 rounded text-xs font-bold border border-red-800 ml-1">X</button>
                </div>
            </header>

            <!-- ===== PAGE: DASHBOARD ===== -->
            <div id="page-dashboard" class="flex-1 overflow-y-auto p-6 space-y-6">
                <div>
                    <h2 class="text-2xl font-bold text-white">Dashboard Hari Ini</h2>
                    <p class="text-gray-400 text-sm" id="liveDateDisplay">...</p>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="bg-gray-800 p-4 rounded-xl border border-gray-700">
                        <p class="text-gray-500 text-xs uppercase font-bold">Total Staff</p>
                        <h2 id="liveTotal" class="text-3xl font-bold text-white">...</h2>
                    </div>
                    <div class="bg-gray-800 p-4 rounded-xl border-l-4 border-green-500 relative overflow-hidden">
                        <p class="text-gray-500 text-xs uppercase font-bold">Hadir</p>
                        <div class="flex items-end gap-2 mt-1">
                            <h2 id="livePresent" class="text-3xl font-bold text-green-400">...</h2>
                            <span class="text-sm text-gray-500 mb-1" id="liveTotalSmall">/ ...</span>
                        </div>
                        <div class="w-full bg-gray-700 h-2 rounded-full mt-2 overflow-hidden">
                            <div id="progressBar" class="bg-green-500 h-full rounded-full transition-all duration-1000"
                                style="width: 0%"></div>
                        </div>
                    </div>
                    <div class="bg-gray-800 p-4 rounded-xl border-l-4 border-yellow-500">
                        <p class="text-gray-500 text-xs uppercase font-bold">Cuti (Hari Ini)</p>
                        <h2 id="liveCuti" class="text-3xl font-bold text-white">0</h2>
                    </div>
                    <div class="bg-gray-800 p-4 rounded-xl border-l-4 border-red-500">
                        <p class="text-gray-500 text-xs uppercase font-bold">Lewat</p>
                        <h2 id="liveLate" class="text-3xl font-bold text-white">0</h2>
                    </div>
                </div>

                <div class="grid grid-cols-1 xl:grid-cols-3 gap-4 items-start">
                    <div class="xl:col-span-2 bg-gray-800 rounded-xl border border-gray-700 overflow-hidden shadow-xl">
                        <div class="p-4 bg-gray-800 border-b border-gray-700 font-bold text-white flex justify-between items-center">
                            <span>📡 Live Attendance Tracker</span>
                            <span id="loaderLive" class="text-yellow-500 text-xs animate-pulse hidden">Updating...</span>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-sm">
                                <thead class="bg-gray-900 text-gray-400 text-xs uppercase">
                                    <tr>
                                        <th class="p-3">Nama</th>
                                        <th class="p-3">Status</th>
                                        <th class="p-3">In / Out</th>
                                        <th class="p-3">Koordinat</th>
                                        <th class="p-3">Lokasi Terkini</th>
                                    </tr>
                                </thead>
                                <tbody id="tableLive" class="divide-y divide-gray-700"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="bg-gray-800 rounded-xl border border-gray-700 shadow-lg overflow-hidden">
                        <div class="p-4 border-b border-gray-700 flex items-center gap-2">
                            <span class="text-base">🗓️</span>
                            <h3 class="text-white font-bold text-sm">Permohonan Cuti (Pending)</h3>
                        </div>
                        <div id="pendingLeaveList" class="space-y-2 p-4 max-h-[500px] overflow-y-auto"></div>
                    </div>
                </div>
            </div>

            <!-- ===== PAGE: HISTORY ===== -->
            <div id="page-history" class="hidden flex-1 overflow-y-auto p-6 space-y-6 bg-gray-900">
                <div class="flex justify-between items-end border-b border-gray-700 pb-4">
                    <div>
                        <h2 class="text-2xl font-bold text-white">Semakan Rekod Lama</h2>
                        <p class="text-gray-400 text-sm">Pilih tarikh atau julat tarikh untuk lihat kehadiran lepas.</p>
                    </div>
                </div>
                <div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden shadow-xl">
                    <div class="px-3 py-2.5 flex flex-wrap items-center gap-2">
                        <div class="flex items-center gap-1.5 flex-shrink-0">
                            <button id="btnModeSingle" onclick="setHistoryMode('single')"
                                class="px-3 py-1 rounded text-xs font-bold border transition bg-yellow-900 text-yellow-300 border-yellow-700">
                                Tarikh Tunggal
                            </button>
                            <button id="btnModeRange" onclick="setHistoryMode('range')"
                                class="px-3 py-1 rounded text-xs font-bold border transition bg-gray-700 text-gray-400 border-gray-600 hover:border-yellow-700">
                                Julat Tarikh
                            </button>
                        </div>
                        <div class="w-px h-5 bg-gray-600 flex-shrink-0"></div>
                        <div id="historyModeSingle" style="display:flex" class="items-center gap-2 flex-1 flex-wrap">
                            <input type="date" id="historyDateInput"
                                class="bg-gray-900 border border-gray-700 text-white px-3 py-1.5 rounded-lg text-xs focus:outline-none focus:border-yellow-500 cursor-pointer flex-shrink-0">
                            <button id="btnSearchSingle" onclick="loadHistoryData()"
                                class="bg-yellow-500 hover:bg-yellow-400 text-black px-4 py-1.5 rounded-lg text-xs font-bold shadow transition flex-shrink-0">
                                Cari Rekod
                            </button>
                        </div>
                        <div id="historyModeRange" style="display:none" class="items-center gap-2 flex-1 flex-wrap">
                            <input type="text" id="historyDateRange" placeholder="Pilih julat tarikh..." readonly
                                class="bg-gray-900 border border-gray-700 text-white px-3 py-1.5 rounded-lg text-xs focus:outline-none focus:border-yellow-500 cursor-pointer w-48">
                            <button id="btnSearchRange" onclick="loadHistoryRange()" disabled
                                class="bg-yellow-500 text-black px-4 py-1.5 rounded-lg text-xs font-bold shadow transition flex-shrink-0 opacity-40 cursor-not-allowed">
                                Cari Rekod
                            </button>
                            <span class="text-gray-600 text-[11px] flex-shrink-0">*maks 14 hari</span>
                        </div>
                    </div>
                </div>
                <div id="historyResult" class="hidden space-y-4"></div>
                <div id="historyEmptyState" class="flex flex-col items-center justify-center py-24 text-center">
                    <div class="w-20 h-20 rounded-full bg-gray-800 border border-gray-700 flex items-center justify-center mb-5 shadow-inner">
                        <span class="text-4xl">📋</span>
